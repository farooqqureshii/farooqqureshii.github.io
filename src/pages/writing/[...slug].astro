---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { formatLongDate, getWordCount, getReadingTime } from "../../lib/utils";

export const prerender = true;

export async function getStaticPaths() {
  const writing = await getCollection("writing");
  return writing.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;

if (!post) {
  throw new Error(`Post not found for slug: ${Astro.params.slug}`);
}

if (!post.data) {
  throw new Error(`Post data is undefined for slug: ${Astro.params.slug}. Post object: ${JSON.stringify(post, null, 2)}`);
}

const { title, date, description } = post.data;
const { Content } = await post.render();

const rawContent = post.body;
const wordCount = getWordCount(rawContent);
const readingTime = getReadingTime(wordCount);

const allPosts = await getCollection("writing");
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const currentIndex = sortedPosts.findIndex((p) => p.slug === post.slug);
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
---

<Layout title={`${title} | Farooq Qureshi`} description={description}>
  <main>
    <p class="text-sm font-medium mb-1">{title}</p>
    <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-6">
      {formatLongDate(date)} · {readingTime} min read
    </p>
    <article class="text-sm leading-relaxed [&_p]:my-4">
      <Content />
    </article>

    <div class="no-link-underline mt-12 pt-8 border-t border-zinc-200 dark:border-zinc-700 flex justify-between items-center text-sm text-zinc-500 dark:text-zinc-400">
      <a href="/writing">← All Writing</a>
      {nextPost && (
        <a href={`/writing/${nextPost.slug}`}>Next: {nextPost.data.title} →</a>
      )}
    </div>
  </main>
</Layout>
