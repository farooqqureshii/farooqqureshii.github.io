>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <h1 class="mb-8 text-3xl font-bold">Sitemap</h1>

    <div class="space-y-8">
      <!-- Main Pages -->
      <section>
        <h2
          class="flexoki:text-flexoki-tx mb-4 text-2xl font-semibold text-zinc-900 dark:text-zinc-100"
        >
          Main Pages
        </h2>
        <div class="grid gap-3">
          <a
            href="/"
            class="flexoki:border-flexoki-ui-3 flexoki:hover:bg-flexoki-ui/30 block rounded-lg border border-zinc-200 p-3 transition-colors hover:bg-zinc-50 dark:border-zinc-700 dark:hover:bg-zinc-800/50"
          >
            <div
              class="flexoki:text-flexoki-tx font-medium text-zinc-900 dark:text-zinc-100"
            >
              Home
            </div>
            <div
              class="flexoki:text-flexoki-tx-2 text-sm text-zinc-600 dark:text-zinc-400"
