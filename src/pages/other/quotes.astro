---
import Layout from "../../layouts/Layout.astro";
import { quotes } from "../../data/quotes";
---

<Layout title="Quotes | FQ" description="Quotes I find meaningful">
  <main>
    <div class="flashlight-hover quotes-container">
      {quotes.map((quote) => (
        <blockquote class="flashlight-item quote-item">
          <p class="quote-text">"{quote.text}"</p>
          <cite class="quote-author">— {quote.author}</cite>
        </blockquote>
      ))}
    </div>
  </main>

  <style>
    :global(html) {
      scroll-behavior: smooth;
    }

    .quotes-container {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }

    .quote-item {
      margin: 0;
      padding: 0.5rem 0;
      border: none;
    }

    .quote-text {
      font-size: 1.0625rem;
      line-height: 1.55;
      margin: 0 0 0.25rem 0;
      font-style: italic;
      color: inherit;
    }

    .quote-author {
      font-size: 0.8125rem;
      font-style: normal;
      opacity: 0.7;
      display: block;
    }
  </style>
</Layout>
