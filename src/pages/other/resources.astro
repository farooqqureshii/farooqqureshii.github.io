---
import Layout from "../../layouts/Layout.astro";
---
<Layout title="Resources | FQ" description="Miscellaneous pages by Farooq Qureshi">
  <main>
    <article class="space-y-6 text-sm leading-relaxed">
    <div>
    <h2 class="text-sm font-medium text-zinc-500 dark:text-zinc-400">Calculus</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5">
      <li>
        <a href="https://tutorial.math.lamar.edu/" target="_blank" rel="noopener">Paul's Online Math Notes</a>
      </li>
      <li>
        <span>Thomas' Calculus Textbook (though Stewart's is also good - I think it it convoluted in it's explanations at times)</span>
      </li>
      <li>
        <a href="https://www.science.smith.edu/~callahan/intromine.html" target="_blank" rel="noopener">Calculus in Context (Five College Calculus Project)</a>
      </li>
    </ul>
    </div>
    <div>
    <h2 class="text-sm font-medium text-zinc-500 dark:text-zinc-400">Linear Algebra</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5">
      <li>
        <a href="https://2prime.github.io/files/linear/midterm_review.pdf" target="_blank" rel="noopener">Linear Algebra Cheat Sheet (Yiping Lu, 2024)</a>
      </li>
      <li>
        <a href="https://minireference.com/static/tutorials/linear_algebra_in_4_pages.pdf" target="_blank" rel="noopener">Linear Algebra in 4 Pages (MiniReference)</a>
      </li>
    </ul>
    </div>
    <div>
    <h2 class="text-sm font-medium text-zinc-500 dark:text-zinc-400">Differential Equations</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5">
      <li>
        <a href="https://www.jirka.org/diffyqs/diffyqs.pdf" target="_blank" rel="noopener">Notes on Diffy Qs: Differential Equations for Engineers (Jirka)</a>
      </li>
      <li>
        <a href="https://people.uncw.edu/hermanr/mat361/ODEsheet.pdf" target="_blank" rel="noopener">ODE Reference Sheet (UNCW)</a>
      </li>
    </ul>
    </div>
    <div>
    <h2 class="text-sm font-medium text-zinc-500 dark:text-zinc-400">Electrical Engineering</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5">
      <li>
        Sanfoundry's <a href="https://www.sanfoundry.com/electrical-engineering-questions-answers/#1st-year-electrical-engineering-mcq" target="_blank" rel="noopener">50,000+ Electrical Engineering MCQ's</a> - sorted by year and topic
      </li>
    </ul>
    </div>
    </article>
  </main>
</Layout>
