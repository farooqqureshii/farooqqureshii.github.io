  { title: "One Hundred Years of Solitude", author: "Gabriel García Márquez", rating: 5, genre: "Fiction, Magical Realism", description: "Magical realism at its finest. Márquez creates a world that feels both fantastical and deeply human.", image: "https://covers.openlibrary.org/b/isbn/9780060883287-M.jpg" },
  { title: "The Stranger", author: "Albert Camus", rating: 4, genre: "Fiction, Literary", description: "Existentialist classic about alienation and absurdity. Camus' spare prose is deceptively simple.", image: "https://covers.openlibrary.org/b/isbn/9780679720201-M.jpg" },
  { title: "The Great Gatsby", author: "F. Scott Fitzgerald", rating: 5, genre: "Fiction, Literary", description: "Perfect American novel about the American Dream. Fitzgerald's prose is luminous and tragic.", image: "https://covers.openlibrary.org/b/isbn/9780743273565-M.jpg" },
  { title: "Slaughterhouse-Five", author: "Kurt Vonnegut", rating: 5, genre: "Fiction, Sci-Fi, Satire", description: "Anti-war masterpiece that's both funny and devastating. Vonnegut's unique voice is unforgettable.", image: "https://covers.openlibrary.org/b/isbn/9780385333849-M.jpg" },
  { title: "The Master and Margarita", author: "Mikhail Bulgakov", rating: 5, genre: "Fiction, Literary, Satire", description: "Surreal and satirical masterpiece about good and evil. Bulgakov's imagination is boundless.", image: "https://covers.openlibrary.org/b/isbn/9780679760801-M.jpg" }
];
---

<Layout title="Books | FQ" description="Books I've read with ratings and thoughts" className="max-w-5xl">
  <main class="books-main">
    <p class="books-intro text-sm text-zinc-500 dark:text-zinc-400 mb-6">
      Books I've read with ratings and thoughts. Hover to isolate, click for details.
    </p>

    <div class="books-toolbar mb-6">
      <input
        type="search"
        id="books-search"
        placeholder="Search by title, author, or genre..."
        class="books-search w-full text-base px-4 py-3 rounded-md border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 text-zinc-900 dark:text-zinc-100 placeholder-zinc-400 dark:placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-400 dark:focus:ring-zinc-500 focus:border-transparent transition-shadow"
        aria-label="Search books"
      />
    </div>

    <div class="flashlight-hover books-grid" id="books-grid" data-flashlight-pinnable>
      {books.map((book, index) => (
        <button
          class="flashlight-item book-cover-btn"
          data-book={JSON.stringify(book)}
          data-rating={book.rating}
          data-title={book.title}
          data-author={book.author}
          data-genre={book.genre || ""}
          data-index={index}
          aria-label={`View details for ${book.title}`}
        >
          <img
            src={book.image}
            alt={book.title}
            class="book-cover"
            loading={index < 12 ? "eager" : "lazy"}
            fetchpriority={index < 8 ? "high" : "auto"}
            decoding="async"
            onload="this.classList.add('loaded')"
            onerror="this.style.display='none'"
          />
        </button>
      ))}
    </div>
  </main>

  <div id="book-modal" class="book-modal" role="dialog" aria-modal="true" aria-labelledby="book-modal-title">
    <div class="book-modal-backdrop"></div>
    <div class="book-modal-content">
      <button class="book-modal-close" aria-label="Close modal">×</button>
      <div class="book-modal-cover"></div>
      <div class="book-modal-body">
        <h2 id="book-modal-title" class="book-modal-title"></h2>
        <p id="book-modal-author" class="book-modal-author"></p>
        <div class="book-modal-rating"></div>
        <p class="book-modal-description"></p>
      </div>
    </div>
  </div>

  <style is:global>
    .books-main {
      max-width: none;
    }

    .books-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-top: 0;
    }

    @media (max-width: 640px) {
      .books-grid {
        grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem;
      }
    }

    .book-cover-btn {
      background: #e5e5e5;
      border: none;
      padding: 0;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease-out;
      overflow: hidden;
      aspect-ratio: 2 / 3;
      position: relative;
      border-radius: 4px;
      animation: bookFadeIn 0.4s ease-out backwards;
    }

    .dark .book-cover-btn {
      background: #2a2a2a;
    }

    .book-cover-btn::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
      animation: shimmer 2s infinite;
    }

    .dark .book-cover-btn::before {
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
    }

    @keyframes shimmer {
      0% { left: -100%; }
      100% { left: 100%; }
    }

    @keyframes bookFadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .book-cover-btn img.loaded { opacity: 1; }
    .book-cover-btn img:not(.loaded) { opacity: 0; }
    .book-cover-btn:has(img.loaded)::before { display: none; }

    .book-cover-btn:hover {
      transform: translateY(-6px) scale(1.03);
      box-shadow: 0 16px 32px -12px rgba(0,0,0,0.3);
    }

    .dark .book-cover-btn:hover {
      box-shadow: 0 16px 32px -12px rgba(0,0,0,0.55);
    }

    .book-cover {
      width: 100%;
      height: 100%;
      display: block;
      aspect-ratio: 2 / 3;
      object-fit: cover;
      transition: opacity 0.3s ease;
    }

    .books-search {
      max-width: 100%;
    }

    .book-modal {
      position: fixed;
      inset: 0;
      z-index: 1000;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }

    .book-modal.show {
      display: flex;
    }

    .book-modal-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.6);
      backdrop-filter: blur(8px);
    }

    .book-modal-content {
      position: relative;
      display: flex;
      gap: 1.5rem;
      background: #F2F0EF;
      color: #0a0a0a;
      border-radius: 12px;
      padding: 1.5rem;
      max-width: 520px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
      animation: modalSlideIn 0.25s ease-out;
    }

    .dark .book-modal-content {
      background: #1f1f1f;
      color: #e5e5e5;
    }

    @keyframes modalSlideIn {
      from { opacity: 0; transform: scale(0.96) translateY(10px); }
      to { opacity: 1; transform: scale(1) translateY(0); }
    }

    .book-modal-cover {
      flex-shrink: 0;
      width: 100px;
      aspect-ratio: 2/3;
      border-radius: 6px;
      overflow: hidden;
      background: #e5e5e5;
    }

    .dark .book-modal-cover {
      background: #2a2a2a;
    }

    .book-modal-cover img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .book-modal-body {
      flex: 1;
      min-width: 0;
    }

    .book-modal-close {
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
      background: none;
      border: none;
      font-size: 1.5rem;
      line-height: 1;
      cursor: pointer;
      color: inherit;
      opacity: 0.5;
      transition: opacity 0.15s ease;
      padding: 0.25rem;
    }

    .book-modal-close:hover { opacity: 1; }

    .book-modal-title {
      font-size: 1.125rem;
      font-weight: 500;
      margin-bottom: 0.25rem;
      padding-right: 2rem;
    }

    .book-modal-author {
      font-size: 0.8125rem;
      opacity: 0.65;
      margin-bottom: 0.5rem;
    }

    .book-modal-rating {
      display: flex;
      gap: 0.125rem;
      margin-bottom: 0.75rem;
    }

    .book-modal-rating .star {
      color: #fbbf24;
      font-size: 0.9rem;
    }

    .book-modal-rating .star.empty {
      color: #6b7280;
      opacity: 0.4;
    }

    .book-modal-description {
      font-size: 0.8125rem;
      line-height: 1.55;
      margin: 0;
      opacity: 0.85;
    }

    .book-cover-btn.hidden {
      display: none !important;
    }

    .book-cover-btn.pinned {
      transform: translateY(-6px) scale(1.03);
      box-shadow: 0 16px 32px -12px rgba(0,0,0,0.3);
    }
    .dark .book-cover-btn.pinned {
      box-shadow: 0 16px 32px -12px rgba(0,0,0,0.55);
    }
  </style>

  <script define:vars={{ books }} is:inline>
    (function() {
      books.slice(0, 12).forEach(book => { const img = new Image(); img.src = book.image; });
      books.slice(12).forEach(book => { const img = new Image(); img.src = book.image; });
    })();

    document.addEventListener('DOMContentLoaded', function() {
      const modal = document.getElementById('book-modal');
      const modalTitle = document.getElementById('book-modal-title');
      const modalAuthor = document.getElementById('book-modal-author');
      const modalRating = document.querySelector('.book-modal-rating');
      const modalDescription = document.querySelector('.book-modal-description');
      const modalCover = document.querySelector('.book-modal-cover');
      const modalClose = document.querySelector('.book-modal-close');
      const modalBackdrop = document.querySelector('.book-modal-backdrop');
      const bookButtons = document.querySelectorAll('.book-cover-btn');
      const searchInput = document.getElementById('books-search');

      function showModal(book) {
        modalTitle.textContent = book.title;
        modalAuthor.textContent = book.author;
        modalRating.innerHTML = '';
        for (var i = 0; i < 5; i++) {
          const star = document.createElement('span');
          star.className = 'star ' + (i < book.rating ? '' : 'empty');
          star.textContent = '★';
          modalRating.appendChild(star);
        }
        modalDescription.textContent = book.description;
        if (modalCover) {
          modalCover.innerHTML = '';
          const img = document.createElement('img');
          img.src = book.image;
          img.alt = book.title;
          modalCover.appendChild(img);
        }
        modal.classList.add('show');
        document.body.style.overflow = 'hidden';
      }

      function hideModal() {
        modal.classList.remove('show');
        document.body.style.overflow = '';
        document.dispatchEvent(new CustomEvent('flashlight-unpin'));
      }

      bookButtons.forEach(btn => {
        btn.addEventListener('click', function() {
          showModal(JSON.parse(btn.getAttribute('data-book')));
        });
      });

      modalClose.addEventListener('click', hideModal);
      modalBackdrop.addEventListener('click', function(e) {
        if (e.target === modalBackdrop) hideModal();
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && modal.classList.contains('show')) {
          hideModal();
        }
      });

      function filterBooks() {
        const q = (searchInput.value || '').toLowerCase().trim();
        bookButtons.forEach(btn => {
          const title = (btn.getAttribute('data-title') || '').toLowerCase();
          const author = (btn.getAttribute('data-author') || '').toLowerCase();
          const genre = (btn.getAttribute('data-genre') || '').toLowerCase();
          const matchSearch = !q || title.includes(q) || author.includes(q) || genre.includes(q);
          btn.classList.toggle('hidden', !matchSearch);
        });
      }

      searchInput.addEventListener('input', filterBooks);

      bookButtons.forEach((btn, i) => {
        btn.style.animationDelay = (i % 24) * 20 + 'ms';
      });
    });
  </script>
</Layout>
