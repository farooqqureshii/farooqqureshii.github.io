  const hashA = (a.title.charCodeAt(0) * 31 + a.author.charCodeAt(0) * 17) % 97;
  const hashB = (b.title.charCodeAt(0) * 31 + b.author.charCodeAt(0) * 17) % 97;
  return hashA - hashB;
});
