---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Tools | FQ" description="Tools I use in my daily life">
  <main>
    <article class="space-y-6 text-sm leading-relaxed">
    <p>
      Here are some tools I use in my daily life.
    </p>
    <ul class="flex flex-col gap-1.5 list-none pl-0">
      <li>
        <a href="https://getupnote.com/" target="_blank" rel="noopener">UpNote</a>
      </li>
      <li>
        <a href="https://calendar.google.com/" target="_blank" rel="noopener">Google Calendar</a>
      </li>
      <li>
        <a href="https://zed.dev/" target="_blank" rel="noopener">Zed</a>
      </li>
      <li>
        <a href="https://cursor.sh/" target="_blank" rel="noopener">Cursor</a>
      </li>
      <li>
        <a href="https://www.figma.com/" target="_blank" rel="noopener">Figma</a>
      </li>
      <li>
        <a href="https://zenbrowser.app/" target="_blank" rel="noopener">Zen Browser</a>
      </li>
    </ul>
    </article>
  </main>
</Layout>
