---
import { SITE_DESCRIPTION } from "../../consts";
import type { Artifact, ArtifactCategory } from "../../data/artifacts";
import { artifacts as baseArtifacts } from "../../data/artifacts";
import Layout from "../../layouts/Layout.astro";

export const prerender = true;

function withCategories(
  a: Artifact,
): Artifact & { categories: ArtifactCategory[] } {
  const cats = a.categories?.length
    ? a.categories
    : a.type === "image"
      ? (["photography"] as ArtifactCategory[])
      : a.type === "video"
        ? (["tools"] as ArtifactCategory[])
        : (["design"] as ArtifactCategory[]);
  return { ...a, categories: cats };
}

const artifacts = baseArtifacts.map(withCategories);

const items = artifacts.filter((a) => {
  if (a.type === "link") return !!a.url;
  if (a.type === "video") return !!a.url;
  if (a.type === "image") return !!a.image;
  return false;
});

const byType: {
  link: typeof items;
  image: typeof items;
  video: typeof items;
} = {
  link: items.filter((i) => i.type === "link"),
  image: items.filter((i) => i.type === "image"),
  video: items.filter((i) => i.type === "video"),
};

// Interleave types so links don't clump in one column.
const itemsMixed: typeof items = [];
while (byType.image.length || byType.link.length || byType.video.length) {
  if (byType.image.length) itemsMixed.push(byType.image.shift()!);
  if (byType.link.length) itemsMixed.push(byType.link.shift()!);
  if (byType.video.length) itemsMixed.push(byType.video.shift()!);
}
---

<Layout
  title="Farooq Q. | Artifacts"
  description={SITE_DESCRIPTION}
  className="max-w-5xl"
>
  <main class="no-link-underline">
    <header class="mb-10">
      <div class="mt-4 inline-flex items-center gap-1 relative p-0.5 max-w-full overflow-x-auto no-scrollbar bg-zinc-100/80 dark:bg-zinc-800/40 border border-zinc-200/50 dark:border-zinc-700/30 rounded-full select-none whitespace-nowrap" style="-webkit-overflow-scrolling: touch; touch-action: pan-x;">
        <div class="tabs-indicator" id="artifacts-indicator"></div>
        <button type="button" class="artifact-tab" data-tab="all">All</button>
        <button type="button" class="artifact-tab" data-tab="link">Links</button>
        <button type="button" class="artifact-tab" data-tab="image">Images</button>
        <button type="button" class="artifact-tab" data-tab="video">Videos</button>
      </div>
    </header>

    <div
      id="artifact-loader"
      class="flex items-center gap-2 text-sm text-zinc-400 dark:text-zinc-500"
      style="transition:opacity 200ms ease; min-height:24px;"
    >
      <span class="artifact-spinner"></span>
      Loading…
    </div>

    <div
      class="flashlight-hover artifact-grid column-gap-4 columns-2 sm:columns-3"
      style="opacity:0;transition:opacity 250ms ease"
    >
      {
        itemsMixed.map((item, index) => (
          <a
            href={item.type === "image" ? item.image : item.url}
            target="_blank"
            rel="noopener"
            class="flashlight-item artifact-card group mb-4 block break-inside-avoid overflow-hidden rounded-lg border border-zinc-200 bg-zinc-50 transition-colors hover:border-zinc-400 dark:border-zinc-800 dark:bg-zinc-900/50 dark:hover:border-zinc-600"
            data-type={item.type}
          >
            {item.type === "image" ? (
              <img
                src={item.image}
                alt={item.alt || item.title || "Artifact image"}
                class="block h-auto w-full"
                style="display:block;width:100%;height:auto;"
                loading={index < 4 ? "eager" : "lazy"}
                decoding="async"
                referrerpolicy="no-referrer"
              />
            ) : (
              <div class="p-3">
                <div class="flex items-start justify-between gap-3">
                  <p class="text-sm leading-snug text-zinc-900 dark:text-zinc-100">
                    {item.title?.trim() || item.domain || (item.url ?? "")}
                  </p>
                  <span class="shrink-0 text-xs text-zinc-400 dark:text-zinc-500">
                    {item.type === "video" ? "▶" : "↗"}
                  </span>
                </div>
                {(item.description || item.domain) && (
                  <p class="mt-1 line-clamp-2 text-xs text-zinc-500 dark:text-zinc-400">
                    {item.description?.trim() || item.domain}
                  </p>
                )}
              </div>
            )}
          </a>
        ))
      }
    </div>
  </main>

  <style>
    .tabs-indicator {
      position: absolute;
      background: rgb(24 24 27);
      border-radius: 9999px;
      transition:
        left 220ms cubic-bezier(0.23, 1, 0.32, 1),
        width 220ms cubic-bezier(0.23, 1, 0.32, 1),
        top 220ms cubic-bezier(0.23, 1, 0.32, 1),
        height 220ms cubic-bezier(0.23, 1, 0.32, 1);
      pointer-events: none;
      z-index: 0;
    }
    html.dark .tabs-indicator {
      background: rgb(244 244 245);
    }
    .artifact-tab {
      position: relative;
      z-index: 10;
      padding: 6px 12px;
      font-size: 12px;
      white-space: nowrap;
      flex-shrink: 0;
      border-radius: 9999px;
      border: 1px solid transparent;
      color: rgb(113 113 122);
      background: transparent;
      transition:
        color 150ms ease,
        transform 100ms ease;
      cursor: pointer;
    }
    html.dark .artifact-tab {
      color: rgb(161 161 170);
    }
    .artifact-tab:hover {
      color: rgb(24 24 27);
    }
    html.dark .artifact-tab:hover {
      color: rgb(244 244 245);
    }
    .artifact-tab:active {
      transform: scale(0.96);
    }
    .artifact-tab.is-active {
      color: #fff;
    }
    html.dark .artifact-tab.is-active {
      color: rgb(24 24 27);
    }
    .artifact-grid {
      column-fill: balance;
    }
    .artifact-spinner {
      display: inline-block;
      width: 12px;
      height: 12px;
      border: 1.5px solid currentColor;
      border-top-color: transparent;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>

  <script is:inline>
    (() => {
      const tabs = Array.from(document.querySelectorAll(".artifact-tab"));
      const cards = Array.from(document.querySelectorAll(".artifact-card"));

      // Fallback broken images (hotlinking / CDN issues) to a nice placeholder.
      const imgEls = Array.from(
        document.querySelectorAll(".artifact-card img"),
      );
      const placeholder =
        "data:image/svg+xml;charset=utf-8," +
        encodeURIComponent(`
          <svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
            <defs>
              <linearGradient id="g" x1="0" x2="1" y1="0" y2="1">
                <stop offset="0" stop-color="#f4f4f5"/>
                <stop offset="1" stop-color="#e4e4e7"/>
              </linearGradient>
            </defs>
            <rect width="1200" height="800" fill="url(#g)"/>
            <rect x="60" y="60" width="1080" height="680" rx="28" fill="rgba(0,0,0,0.04)"/>
            <text x="100" y="160" font-family="Inter, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif" font-size="42" fill="rgba(0,0,0,0.35)">
              Image unavailable
            </text>
          </svg>
        `);

      imgEls.forEach((img) => {
        img.addEventListener(
          "error",
          () => {
            if (img.dataset.fallbackApplied) return;
            img.dataset.fallbackApplied = "1";
            img.src = placeholder;
            img.style.opacity = "0.9";
          },
          { once: false },
        );
      });

      const indicator = document.getElementById("artifacts-indicator");
      const updateIndicator = (activeTab) => {
        if (!indicator || !activeTab) return;
        indicator.style.left = `${activeTab.offsetLeft}px`;
        indicator.style.width = `${activeTab.offsetWidth}px`;
        indicator.style.top = `${activeTab.offsetTop}px`;
        indicator.style.height = `${activeTab.offsetHeight}px`;
      };

      const setActive = (name) => {
        tabs.forEach((t) => {
          const isAct = t.dataset.tab === name;
          t.classList.toggle("is-active", isAct);
          if (isAct) {
            updateIndicator(t);
          }
        });
        cards.forEach((c) => {
          const type = c.dataset.type;
          const show = name === "all" || type === name;
          c.style.display = show ? "block" : "none";
        });
      };

      tabs.forEach((t) =>
        t.addEventListener("click", () => setActive(t.dataset.tab)),
      );
      
      // Initialize slider positioning layout safely
      setTimeout(() => {
        setActive("all");
      }, 60);

      window.addEventListener("resize", () => {
        const activeTab = tabs.find((t) => t.classList.contains("is-active"));
        if (activeTab) updateIndicator(activeTab);
      });

      const grid = document.querySelector(".artifact-grid");
      const loader = document.getElementById("artifact-loader");

      const reveal = () => {
        if (loader) loader.style.opacity = "0";
        grid.style.opacity = "1";
        // Keep the loader in the flow to avoid layout shift; hide visibility instead
        setTimeout(() => {
          if (loader) loader.style.visibility = "hidden";
        }, 220);
      };

      // Reveal as soon as every image has loaded or errored (eager loading means this is fast)
      let timer = setTimeout(reveal, 2000); // hard cap
      if (imgEls.length === 0) {
        clearTimeout(timer);
        reveal();
      } else {
        let remaining = imgEls.length;
        const check = () => {
          if (--remaining === 0) {
            clearTimeout(timer);
            reveal();
          }
        };
        imgEls.forEach((img) => {
          if (img.complete) {
            check();
          } else {
            img.addEventListener("load", check, { once: true });
            img.addEventListener("error", check, { once: true });
          }
        });
      }
    })();
  </script>
</Layout>
