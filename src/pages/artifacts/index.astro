---
import { SITE_DESCRIPTION } from "../../consts";
import Layout from "../../layouts/Layout.astro";
import { artifacts as baseArtifacts } from "../../data/artifacts";
import type { Artifact, ArtifactCategory } from "../../data/artifacts";

export const prerender = true;

function withCategories(a: Artifact): Artifact & { categories: ArtifactCategory[] } {
  const cats = a.categories?.length
    ? a.categories
    : a.type === "image"
      ? (["photography"] as ArtifactCategory[])
      : a.type === "video"
        ? (["tools"] as ArtifactCategory[])
        : (["design"] as ArtifactCategory[]);
  return { ...a, categories: cats };
}

const artifacts = baseArtifacts.map(withCategories);

const items = artifacts.filter((a) => {
  if (a.type === "link") return !!a.url;
  if (a.type === "video") return !!a.url;
  if (a.type === "image") return !!a.image;
  return false;
});
---

<Layout title="Artifacts | Farooq Qureshi" description={SITE_DESCRIPTION} className="max-w-5xl">
  <main class="no-link-underline">
    <header class="mb-10">
      <p class="text-sm text-zinc-900 dark:text-zinc-100">
        A small stash of links, images, and videos I’ve bookmarked.
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        <button type="button" class="artifact-tab" data-tab="all">All</button>
        <button type="button" class="artifact-tab" data-tab="link">Links</button>
        <button type="button" class="artifact-tab" data-tab="image">Images</button>
        <button type="button" class="artifact-tab" data-tab="video">Videos</button>
      </div>
    </header>

    <div class="flashlight-hover artifact-grid columns-2 sm:columns-3 column-gap-4">
      {items.map((item) => (
        <a
          href={item.type === "image" ? item.image : item.url}
          target="_blank"
          rel="noopener"
          class="flashlight-item artifact-card block break-inside-avoid mb-4 rounded-lg overflow-hidden bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 hover:border-zinc-400 dark:hover:border-zinc-600 transition-colors group"
          data-type={item.type}
        >
          {item.type === "image" ? (
            <img
              src={item.image}
              alt={item.alt || item.title || "Artifact image"}
              class="w-full h-auto block"
              loading="lazy"
            />
          ) : (
            <div class="p-3">
              <div class="flex items-start justify-between gap-3">
                <p class="text-sm text-zinc-900 dark:text-zinc-100 leading-snug">
                  {item.title?.trim() || item.domain || (item.url ?? "")}
                </p>
                <span class="text-xs text-zinc-400 dark:text-zinc-500 shrink-0">
                  {item.type === "video" ? "▶" : "↗"}
                </span>
              </div>
              {(item.description || item.domain) && (
                <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-400 line-clamp-2">
                  {item.description?.trim() || item.domain}
                </p>
              )}
            </div>
          )}
        </a>
      ))}
    </div>
  </main>

  <style>
    .artifact-tab {
      padding: 6px 12px;
      font-size: 12px;
      border-radius: 9999px;
      border: 1px solid rgb(228 228 231);
      color: rgb(63 63 70);
      transition: border-color 150ms ease, background-color 150ms ease, color 150ms ease;
    }
    html.dark .artifact-tab {
      border-color: rgb(63 63 70);
      color: rgb(212 212 216);
    }
    .artifact-tab:hover {
      border-color: rgb(161 161 170);
      color: rgb(24 24 27);
    }
    html.dark .artifact-tab:hover {
      border-color: rgb(113 113 122);
      color: rgb(244 244 245);
    }
    .artifact-tab.is-active {
      background: rgb(24 24 27);
      border-color: rgb(24 24 27);
      color: #fff;
    }
    html.dark .artifact-tab.is-active {
      background: rgb(244 244 245);
      border-color: rgb(244 244 245);
      color: rgb(24 24 27);
    }
    .artifact-grid {
      column-fill: balance;
    }
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>

  <script is:inline>
    (() => {
      const tabs = Array.from(document.querySelectorAll(".artifact-tab"));
      const cards = Array.from(document.querySelectorAll(".artifact-card"));

      const setActive = (name) => {
        tabs.forEach((t) => t.classList.toggle("is-active", t.dataset.tab === name));
        cards.forEach((c) => {
          const type = c.dataset.type;
          const show = name === "all" || type === name;
          c.style.display = show ? "block" : "none";
        });
      };

      tabs.forEach((t) => t.addEventListener("click", () => setActive(t.dataset.tab)));
      setActive("all");
    })();
  </script>
</Layout>
