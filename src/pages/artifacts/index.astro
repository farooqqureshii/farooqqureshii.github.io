---
import { SITE_DESCRIPTION } from "../../consts";
import Layout from "../../layouts/Layout.astro";
import { artifacts as baseArtifacts } from "../../data/artifacts";
import type { Artifact, ArtifactType, ArtifactCategory } from "../../data/artifacts";
import { CATEGORY_LABELS } from "../../data/artifact-categories";
import { getLinkThumbnails } from "../../lib/link-thumbnail";

export const prerender = true;

// Fetch og:image / twitter:image thumbnails for links at build time
const linkUrls = baseArtifacts
  .filter((a): a is Artifact & { url: string } => a.type === "link" && !!a.url)
  .map((a) => a.url);
const thumbnails = await getLinkThumbnails(linkUrls);

function withCategories(a: Artifact): Artifact & { categories: ArtifactCategory[] } {
  const cats = a.categories?.length
    ? a.categories
    : a.type === "image"
      ? (["photography"] as ArtifactCategory[])
      : a.type === "video"
        ? (["tools"] as ArtifactCategory[])
        : (["design"] as ArtifactCategory[]);
  return { ...a, categories: cats };
}

const artifacts = baseArtifacts.map((a) => {
  const item = withCategories(a);
  if (a.type === "link" && a.url) {
    return { ...item, thumbnail: thumbnails.get(a.url) ?? null };
  }
  return item;
});

const allCategories = [...new Set(artifacts.flatMap((a) => a.categories))].sort();
const typeFilters: { value: ArtifactType | "all"; label: string }[] = [
  { value: "all", label: "All" },
  { value: "image", label: "Images" },
  { value: "link", label: "Links" },
  { value: "video", label: "Videos" },
];
const categoryFilters = allCategories.map((c) => ({
  value: c,
  label: CATEGORY_LABELS[c] ?? c,
}));
---

<Layout title="Artifacts | Farooq Qureshi" description={SITE_DESCRIPTION} className="max-w-5xl">
  <main class="no-link-underline">
    <h1 class="text-sm font-medium mb-8">Gems on the web that I've came across.</h1>

    <!-- Filters: Type + Category -->
    <div class="flex flex-col gap-4 mb-8">
      <div class="flex flex-wrap gap-2 items-center">
        <span class="text-[10px] uppercase tracking-wider text-zinc-400 dark:text-zinc-500 mr-1">Type</span>
        {typeFilters.map((f) => (
          <button
            type="button"
            class="artifact-type-filter px-3 py-1.5 text-xs rounded-full border transition-colors"
            data-filter={f.value}
          >
            {f.label}
          </button>
        ))}
      </div>
      <div class="flex flex-wrap gap-2 items-center">
        <span class="text-[10px] uppercase tracking-wider text-zinc-400 dark:text-zinc-500 mr-1">Category</span>
        {categoryFilters.map((f) => (
          <button
            type="button"
            class="artifact-category-filter px-3 py-1.5 text-xs rounded-full border transition-colors"
            data-filter={f.value}
          >
            {f.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Masonry grid -->
    <div class="flashlight-hover artifact-grid columns-2 sm:columns-3 column-gap-4">
      {artifacts.map((item) => (
        <a
          href={item.url || item.image || "#"}
          target={item.url || item.image ? "_blank" : undefined}
          rel={item.url || item.image ? "noopener" : undefined}
          class="flashlight-item artifact-card block break-inside-avoid mb-4 rounded-lg overflow-hidden bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 hover:border-zinc-400 dark:hover:border-zinc-600 transition-colors group"
          data-type={item.type}
          data-categories={item.categories?.join(",") ?? ""}
        >
          {item.type === "image" && item.image ? (
            <div class="overflow-hidden rounded-t-lg bg-zinc-100 dark:bg-zinc-800">
              <img
                src={item.image}
                alt={item.alt || item.title}
                class="w-full h-auto block"
                loading="lazy"
              />
            </div>
          ) : item.type === "link" && item.url ? (
            <div class="aspect-[4/3] overflow-hidden relative flex items-center justify-center">
              {item.thumbnail ? (
                <img
                  src={item.thumbnail}
                  alt=""
                  class="w-full h-full object-cover"
                  loading="lazy"
                  onerror="this.style.display='none';this.nextElementSibling?.classList.remove('hidden');"
                />
              ) : null}
              <div
                class={`artifact-placeholder w-full h-full ${item.thumbnail ? 'hidden' : ''}`}
                data-domain={item.domain || item.url}
              />
            </div>
          ) : item.type === "link" ? (
            <div class="aspect-[4/3] flex items-center justify-center bg-zinc-200 dark:bg-zinc-800">
              <span class="text-2xl text-zinc-500 dark:text-zinc-400">↗</span>
            </div>
          ) : (
            <div class="aspect-[4/3] flex items-center justify-center bg-zinc-200 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400">
              <span class="text-2xl">▶</span>
            </div>
          )}
          {(item.title || item.alt || item.description || item.domain) && (
            <div class="p-3">
              {(item.title || item.alt || item.domain) && (
                <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100 line-clamp-2">
                  {item.title || item.alt || item.domain || "—"}
                </p>
              )}
              {item.description && (
                <p class={`text-xs text-zinc-500 dark:text-zinc-400 line-clamp-2 group-hover:text-zinc-600 dark:group-hover:text-zinc-300 ${item.title || item.alt || item.domain ? "mt-0.5" : ""}`}>
                  {item.description}
                </p>
              )}
              {item.domain && (
                <p class={`text-[10px] text-zinc-400 dark:text-zinc-500 truncate group-hover:text-zinc-500 dark:group-hover:text-zinc-400 ${(item.title || item.alt || item.description) ? "mt-1" : ""}`}>
                  {item.domain}
                </p>
              )}
            </div>
          )}
        </a>
      ))}
    </div>
  </main>

  <style>
    .artifact-grid {
      column-fill: balance;
    }
    .artifact-card[data-type="image"] .aspect-[4/3] img {
      min-height: 100%;
    }
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .artifact-placeholder {
      background: linear-gradient(135deg, #e8e4dc 0%, #d4cfc4 50%, #c4bfb2 100%);
    }
    html.dark .artifact-placeholder {
      background: linear-gradient(135deg, #2a2824 0%, #1f1d1a 50%, #181614 100%);
    }
    /* Filter buttons: inactive */
    .artifact-type-filter,
    .artifact-category-filter {
      border-color: rgb(228 228 231);
      color: rgb(82 82 91);
    }
    html.dark .artifact-type-filter,
    html.dark .artifact-category-filter {
      border-color: rgb(63 63 70);
      color: rgb(161 161 170);
    }
    /* Filter buttons: active */
    .artifact-type-filter.active,
    .artifact-category-filter.active {
      background: rgb(24 24 27);
      color: white;
      border-color: rgb(24 24 27);
    }
    html.dark .artifact-type-filter.active,
    html.dark .artifact-category-filter.active {
      background: rgb(244 244 245);
      color: rgb(24 24 27);
      border-color: rgb(244 244 245);
    }
    /* Filter buttons: hover - keep text visible */
    .artifact-type-filter:hover,
    .artifact-category-filter:hover {
      border-color: rgb(161 161 170);
      color: rgb(24 24 27);
    }
    html.dark .artifact-type-filter:hover,
    html.dark .artifact-category-filter:hover {
      border-color: rgb(113 113 122);
      color: rgb(244 244 245);
    }
    .artifact-type-filter.active:hover,
    .artifact-category-filter.active:hover {
      background: rgb(39 39 42);
      color: white;
      border-color: rgb(39 39 42);
    }
    html.dark .artifact-type-filter.active:hover,
    html.dark .artifact-category-filter.active:hover {
      background: rgb(228 228 231);
      color: rgb(24 24 27);
      border-color: rgb(228 228 231);
    }
  </style>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const typeFilters = document.querySelectorAll(".artifact-type-filter");
      const categoryFilters = document.querySelectorAll(".artifact-category-filter");
      const cards = document.querySelectorAll(".artifact-card");

      let activeType = "all";
      let activeCategory: string | null = null;

      function applyFilters() {
        cards.forEach((card) => {
          const type = (card as HTMLElement).dataset.type;
          const categories = ((card as HTMLElement).dataset.categories ?? "").split(",").filter(Boolean);
          const typeMatch = activeType === "all" || type === activeType;
          const categoryMatch = !activeCategory || categories.includes(activeCategory);
          (card as HTMLElement).style.display = typeMatch && categoryMatch ? "block" : "none";
        });
      }

      function setActiveType(value: string) {
        activeType = value;
        typeFilters.forEach((btn) => {
          const el = btn as HTMLButtonElement;
          el.classList.toggle("active", el.dataset.filter === value);
        });
        applyFilters();
      }

      function setActiveCategory(value: string | null) {
        activeCategory = value;
        categoryFilters.forEach((btn) => {
          const el = btn as HTMLButtonElement;
          el.classList.toggle("active", el.dataset.filter === value);
        });
        applyFilters();
      }

      typeFilters.forEach((btn) => {
        btn.addEventListener("click", () => setActiveType((btn as HTMLButtonElement).dataset.filter ?? "all"));
      });
      categoryFilters.forEach((btn) => {
        btn.addEventListener("click", () => {
          const val = (btn as HTMLButtonElement).dataset.filter;
          setActiveCategory(activeCategory === val ? null : val ?? null);
        });
      });

      setActiveType("all");
    });
  </script>
</Layout>
