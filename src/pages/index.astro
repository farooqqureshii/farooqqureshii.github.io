---
import { SITE_DESCRIPTION } from "../consts";
import IndexLayout from "../layouts/IndexLayout.astro";
---

<IndexLayout title="Farooq Qureshi" description={SITE_DESCRIPTION}>
  <main class="index-page">
    <article class="index-content space-y-4 text-sm leading-relaxed">
      <p data-stagger="1">
        Hi! I'm a third-year <a
          href="https://www.uoee.rocks/"
          target="_blank"
          rel="noopener">Electrical Engineering</a
        > student at <a href="https://uottawa.ca" target="_blank" rel="noopener"
          >the University of Ottawa</a
        >. This summer, I'm working at <a
          href="https://www.fleetway.ca/en/"
          target="_blank"
          rel="noopener">Fleetway</a
        > as a Junior Electrical Engineer on the Halifax-class and River-class ships
        for the Canadian Navy.
      </p>
      <p data-stagger="2">
        Before this, I led the team behind <a
          href="https://2026.uottahack.ca/"
          target="_blank"
          rel="noopener">uOttaHack</a
        >. Before that, I debated competitively internationally and now coach.
      </p>
      <p data-stagger="3">
        I'm interested in analog IC and semiconductor device
        design. Particularly CMOS technology, transistor-level circuit design,
        mixed-signal systems and signal conditioning circuits.
      </p>
      <p data-stagger="4">
        In my free time, I <a href="/other/books">read</a>, <a href="/writing"
          >write</a
          > and love <span class="flow-gradient" data-text="design engineering">design engineering</span>.
      </p>
      <p data-stagger="5">
        I'm currently reading <em>Stranger in a Strange Land</em> by Robert A.
        Heinlein. I last listened to <a
          href="#"
          id="spotify-last-song-link"
          target="_blank"
          rel="noopener noreferrer"
        ><span id="spotify-last-song">a song</span></a> by <span
          id="spotify-last-artist">an artist</span
        >.
      </p>
      <p data-stagger="6">
        Please feel free to <a href="#" id="look-around-btn">look around</a>,
        say <a href="mailto:farooq.qureshi@outlook.com">hi</a>, browse my <a
          href="https://www.cosmos.so/farooqqureshi"
          target="_blank"
          rel="noopener">saves</a
        >, or view my <a
          href="https://linkedin.com/in/farooqq"
          target="_blank"
          rel="noopener">experience</a
        >.
      </p>
      <p data-stagger="7">
        This page was last updated on May 20. <span class="thank-wrap">Thank you for stopping by.
          <span class="marquee" aria-hidden="true">
            <svg class="marquee-svg" width="220" height="48" viewBox="0 0 220 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <defs>
                <path id="rectPath" d="M8 8 h204 a8 8 0 0 1 8 8 v16 a8 8 0 0 1 -8 8 h-204 a8 8 0 0 1 -8 -8 v-16 a8 8 0 0 1 8 -8 z" />
              </defs>
              <use href="#rectPath" fill="none" stroke="currentColor" stroke-opacity="0.12" stroke-width="1.2" />
              <text font-family="Inter, system-ui, -apple-system, Arial" font-size="10" fill="currentColor">
                <textPath href="#rectPath" startOffset="0%">
                  HAVE A GREAT DAY 😊  HAVE A GREAT DAY 😊  HAVE A GREAT DAY 😊  HAVE A GREAT DAY 😊
                  <animate attributeName="startOffset" from="0%" to="-100%" dur="8s" repeatCount="indefinite" />
                </textPath>
              </text>
            </svg>
          </span>
        </span>
      </p>
    </article>
  </main>

  <style>
    @keyframes indexFadeIn {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .index-content [data-stagger] {
      opacity: 0;
      transform: translateY(8px);
      animation: indexFadeIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    .index-content [data-stagger="1"] {
      animation-delay: 220ms;
    }
    .index-content [data-stagger="2"] {
      animation-delay: 290ms;
    }
    .index-content [data-stagger="3"] {
      animation-delay: 360ms;
    }
    .index-content [data-stagger="4"] {
      animation-delay: 430ms;
    }
    .index-content [data-stagger="5"] {
      animation-delay: 500ms;
    }
    .index-content [data-stagger="6"] {
      animation-delay: 570ms;
    }
    .index-content [data-stagger="7"] {
      animation-delay: 640ms;
    }

    /* Flowing gradient for specific words (on hover only) */
    .flow-gradient {
      position: relative;
      color: inherit;
      -webkit-text-fill-color: initial;
    }

    .flow-gradient:hover {
      background: linear-gradient(90deg,#ff6b6b 0%,#f8e71c 25%,#7bed9f 50%,#4facfe 75%,#a29bfe 100%);
      background-size: 300% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: flow 4s linear infinite;
    }

    @keyframes flow {
      from { background-position: 0% 50%; }
      to { background-position: 100% 50%; }
    }

    /* Marquee rectangle for the thank-you line */
    .thank-wrap { position: relative; display: inline-block; }
    .thank-wrap .marquee {
      position: absolute;
      left: -8px;
      right: -8px;
      top: -8px;
      bottom: -8px;
      border-radius: 10px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(0,0,0,0.06);
      display: flex;
      align-items: center;
      padding: 6px 10px;
      overflow: hidden;
      pointer-events: none;
      opacity: 0;
      transform: translateY(6px);
      transition: opacity .28s ease, transform .28s ease;
      mix-blend-mode: screen;
    }
    .thank-wrap:hover .marquee { opacity: 1; transform: translateY(0); }

    .marquee-track { display: inline-block; white-space: nowrap; font-weight: 600; letter-spacing: 0.04em; color: currentColor; }
    .marquee-track svg { margin-left: 8px; vertical-align: middle; }
    .marquee-track { animation: marquee 6s linear infinite; }
    @keyframes marquee { from { transform: translateX(100%); } to { transform: translateX(-100%); } }

  </style>
  <script>
    async function updateSpotifyTrack() {
      const songElement = document.getElementById("spotify-last-song");
      const artistElement = document.getElementById("spotify-last-artist");
      const linkElement = document.getElementById(
        "spotify-last-song-link"
      ) as HTMLAnchorElement | null;

      if (!songElement || !artistElement || !linkElement) {
        return;
      }

      try {
        const response = await fetch("/api/spotify-now-playing/", {
          cache: "no-store",
        });

        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }

        const data = await response.json();

        if (data?.title && data?.artist) {
          songElement.textContent = data.title;
          artistElement.textContent = data.artist;

          if (data.songUrl) {
            linkElement.href = data.songUrl;
            linkElement.style.pointerEvents = "auto";
          } else {
            linkElement.href = "#";
            linkElement.style.pointerEvents = "none";
          }
        } else {
          songElement.textContent = "a song";
          artistElement.textContent = "an artist";
          linkElement.href = "#";
          linkElement.style.pointerEvents = "none";
        }
      } catch (error) {
        console.error("Error fetching Spotify data:", error);
      }
    }

    document
      .getElementById("look-around-btn")
      ?.addEventListener("click", (e) => {
        e.preventDefault();
        document.getElementById("hamburger-btn")?.click();
      });

    updateSpotifyTrack();
  </script>
</IndexLayout>
