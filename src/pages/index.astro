---
import { SITE_DESCRIPTION } from "../consts";
import IndexLayout from "../layouts/IndexLayout.astro";
import EmailReveal from "../components/EmailReveal.astro";
---

<IndexLayout title="Farooq Qureshi" description={SITE_DESCRIPTION}>
  <main class="index-page no-link-underline">
    <nav class="index-nav flashlight-hover flex flex-col gap-2 text-sm">
      <a href="/about" class="flashlight-item index-nav-link" data-stagger="1">About</a>
      <a href="/projects" class="flashlight-item index-nav-link" data-stagger="2">Projects</a>
      <a href="/writing" class="flashlight-item index-nav-link" data-stagger="3">Writing</a>
      <a href="/artifacts" class="flashlight-item index-nav-link" data-stagger="4">Artifacts</a>
      <a href="/other" class="flashlight-item index-nav-link" data-stagger="5">Other</a>
      <EmailReveal />
      <a href="https://drive.google.com/file/d/1sM9b3G5AbRIG-kDz68KOzGxeETeKm8rN/view?usp=sharing" target="_blank" rel="noopener" class="flashlight-item index-nav-link" data-stagger="7">Résumé</a>
      <a href="https://linkedin.com/in/farooqq" target="_blank" rel="noopener" class="flashlight-item index-nav-link" data-stagger="8">LinkedIn</a>
      <a href="https://github.com/farooqqureshii" target="_blank" rel="noopener" class="flashlight-item index-nav-link" data-stagger="9">GitHub</a>
    </nav>
  </main>
</IndexLayout>

<style>
  @keyframes indexFadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .index-nav-link {
    opacity: 0;
    transform: translateY(8px);
    animation: indexFadeIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  /* Flashlight override */
  .index-nav.flashlight-hover.active .flashlight-item {
    opacity: 0.35 !important;
  }
  .index-nav.flashlight-hover.active .flashlight-item.hovered {
    opacity: 1 !important;
  }
  /* Explicit stagger by data attribute - no nth-child ambiguity */
  .index-nav-link[data-stagger="1"] { animation-delay: 80ms; }
  .index-nav-link[data-stagger="2"] { animation-delay: 135ms; }
  .index-nav-link[data-stagger="3"] { animation-delay: 190ms; }
  .index-nav-link[data-stagger="4"] { animation-delay: 245ms; }
  .index-nav-link[data-stagger="5"] { animation-delay: 300ms; }
  .index-nav-link[data-stagger="7"] { animation-delay: 410ms; }
  .index-nav-link[data-stagger="8"] { animation-delay: 465ms; }
  .index-nav-link[data-stagger="9"] { animation-delay: 520ms; }
</style>
