---
import { SITE_DESCRIPTION } from "../consts";
import IndexLayout from "../layouts/IndexLayout.astro";
---

<IndexLayout title="Farooq Qureshi" description={SITE_DESCRIPTION}>
  <main class="index-page">
    <article class="index-content space-y-4 text-sm leading-relaxed">
      <p data-stagger="1">
        Hi! I'm a third year <a
          href="https://www.uoee.rocks/"
          target="_blank"
          rel="noopener">Electrical Engineering</a
        > student at <a href="https://uottawa.ca" target="_blank" rel="noopener"
          >the University of Ottawa</a
        >. This summer, I'm working at <a
          href="https://www.fleetway.ca/en/"
          target="_blank"
          rel="noopener">Fleetway</a
        > as a Junior Electrical Engineer where I work on the Halifax-class frigates
        for the Canadian Navy.
      </p>
      <p data-stagger="2">
        Before this, I led the team behind <a
          href="https://2026.uottahack.ca/"
          target="_blank"
          rel="noopener">uOttaHack</a
        >, the largest technology event in Ottawa. Before that, I was a
        competitive debater, winning at Stanford and Harvard's invitational
        tournaments. I now coach students who've won the Canadian National
        Debating Championships, Harvard, Yale and Princeton Invitationals.
      </p>
      <p data-stagger="3">
        Professionally, I'm interested in analog IC and semiconductor device
        design. Particularly CMOS technology, transistor-level circuit design,
        and mixed-signal systems. I also have an interest in amplifier design,
        biasing networks, and signal conditioning circuits.
      </p>
      <p data-stagger="4">
        In my free time, I <a href="/other/books">read</a>, <a href="/writing"
          >write</a
        > and love design engineering.
      </p>
      <p data-stagger="5">
        Current favourite book is <em>Stranger in a Strange Land</em> by Robert A.
        Heinlein. Current favourite artist is Leon Bridges and song is <em
          >Spacey</em
        > by the Rose Hips.
      </p>
      <p data-stagger="6">
        Please feel free to <a href="#" id="look-around-btn">look around</a>,
        say <a href="mailto:farooq.qureshi@outlook.com">hi</a>, browse my <a
          href="https://www.cosmos.so/farooqqureshi"
          target="_blank"
          rel="noopener">saves</a
        >, or view my <a
          href="https://linkedin.com/in/farooqq"
          target="_blank"
          rel="noopener">experience</a
        >.
      </p>
      <p data-stagger="7">
        This page was last updated on {
          new Date().toLocaleDateString("en-CA", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }.
      </p>
    </article>
  </main>

  <style>
    @keyframes indexFadeIn {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .index-content [data-stagger] {
      opacity: 0;
      transform: translateY(8px);
      animation: indexFadeIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    .index-content [data-stagger="1"] {
      animation-delay: 220ms;
    }
    .index-content [data-stagger="2"] {
      animation-delay: 290ms;
    }
    .index-content [data-stagger="3"] {
      animation-delay: 360ms;
    }
    .index-content [data-stagger="4"] {
      animation-delay: 430ms;
    }
    .index-content [data-stagger="5"] {
      animation-delay: 500ms;
    }
    .index-content [data-stagger="6"] {
      animation-delay: 570ms;
    }
    .index-content [data-stagger="7"] {
      animation-delay: 640ms;
    }
  </style>
  <script>
    document
      .getElementById("look-around-btn")
      ?.addEventListener("click", (e) => {
        e.preventDefault();
        document.getElementById("hamburger-btn")?.click();
      });
  </script>
</IndexLayout>
