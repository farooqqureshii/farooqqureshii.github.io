<script>
  import { play, setEnabled } from "cuelume";

  // Prevent multiple setup executions during runtime hot-reloads
  const globalKey = "__audio_effects_setup__";
  if (!(window as any)[globalKey]) {
    (window as any)[globalKey] = true;

    // Track timestamps for throttling and overlap control
    let lastPlayTime = 0;
    let lastClickTime = 0;
    let lastHoverTime = 0;

    // Synchronize mute status with client preference
    const syncMuteState = () => {
      const isMuted = localStorage.sound === "off";
      setEnabled(!isMuted);
    };

    // Initialize state on load
    syncMuteState();

    // Listen for sound toggling changes from settings menu
    window.addEventListener("sound-toggled", syncMuteState);

    // Safeguard to only trigger hover effects on fine pointer devices (mouse/trackpad)
    const hoverQuery = window.matchMedia("(hover: hover) and (pointer: fine)");

    function playSound(soundName: any, ignoreThrottle = false) {
      if (localStorage.sound === "off") return;
      const now = Date.now();
      // Enforce clean acoustic separations: avoid overlapping sound bursts
      if (!ignoreThrottle && now - lastPlayTime < 80) {
        return;
      }
      lastPlayTime = now;
      play(soundName);
    }

    // Delegated Hover Listener
    document.addEventListener("mouseover", (e) => {
      if (!hoverQuery.matches) return;

      const targetEl = e.target as HTMLElement;
      if (!targetEl) return;

      // Do not play hover sounds over high-frequency animated elements like shimmers
      if (targetEl.closest("[data-gradient-shimmer]")) return;

      const interactive = targetEl.closest("a, button, [role='button'], .flashlight-item");
      if (!interactive) return;

      // Prevent redundant hover plays when crossing internal element borders
      if (e.relatedTarget && interactive.contains(e.relatedTarget as Node)) {
        return;
      }

      const now = Date.now();
      // Suppress hover triggers immediately after clicking to allow clean navigation and page transitions
      if (now - lastClickTime < 350) return;
      // Impose menu-sweeping throttle limit
      if (now - lastHoverTime < 120) return;
      lastHoverTime = now;

      // links, buttons, headers, footers, swatches, formats, tabs: clean click-like tick
      playSound("tick");
    });

    // Delegated Click/Press Listener
    document.addEventListener("click", (e) => {
      const targetEl = e.target as HTMLElement;
      if (!targetEl) return;

      const interactive = targetEl.closest("a, button, [role='button'], .flashlight-item");
      if (!interactive) return;

      lastClickTime = Date.now();

      // Check if action corresponds to a success outcome (e.g. copying email)
      if (interactive.matches("#email-copy-btn, .copy-btn")) {
        playSound("success", true);
        return;
      }

      // Check if this action behaves as a toggle / state change
      const isToggle = interactive.matches("#theme-toggle, #menu-theme-toggle, #menu-sound-toggle, .project-tab, .artifact-tab, #hamburger-btn, #menu-close, .tf-swatch, .tf-btn");

      if (isToggle) {
        // tab switches, settings toggles, and format swatches: mechanical click-clack
        playSound("toggle", true);
      } else {
        // general link routing and presses: bright release click
        playSound("release", true);
      }
    }, { capture: true });

    // Unblock/resume Web Audio context on mobile touch start gesture
    const unlockMobileAudio = () => {
      play("tick");
      document.removeEventListener("touchstart", unlockMobileAudio);
    };
    document.addEventListener("touchstart", unlockMobileAudio, { once: true, passive: true });
  }
</script>
