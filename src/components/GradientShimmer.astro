---
interface Props {
  text?: string;
  gradient?: "sunrise" | "bubble" | "peach" | "tonic" | "mint" | "spring" | "twilight" | "bay";
  easing?: "smooth" | "gentle" | "snappy" | "linear";
  duration?: number;
  spread?: number;
  angle?: number;
  pauseBetween?: number;
}

const {
  text,
  gradient = "sunrise",
  easing = "smooth",
  duration = 1.45,
  spread = 3,
  angle = 105,
  pauseBetween = 700,
} = Astro.props;
---

<span
  class="gradient-shimmer-text"
  data-gradient-shimmer
  data-gradient={gradient}
  data-easing={easing}
  data-duration={duration}
  data-spread={spread}
  data-angle={angle}
  data-pause={pauseBetween}
>
  <slot>{text}</slot>
</span>

<style is:global>
  .gradient-shimmer-text {
    position: relative;
    display: inline-block;
    background-repeat: no-repeat;
    background-size: 100% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    background-color: var(--gs-base, currentColor);
    will-change: background-position;
  }
</style>

<script>
  interface GradientStop {
    color: string;
    position: number;
  }

  const lb = 0.44;
  
  const is: Record<string, GradientStop[]> = {
    sunrise: [
      {color:"#B6D3EF",position:0},
      {color:"#CAD1D7",position:.153},
      {color:"#D7CFC8",position:.252},
      {color:"#E1CDB9",position:.341},
      {color:"#EAC6A5",position:.424},
      {color:"#EDB185",position:.505},
      {color:"#EF9B62",position:.586},
      {color:"#F18F60",position:.669},
      {color:"#F48D7A",position:.758},
      {color:"#F78A94",position:.857},
      {color:"#F888A0",position:1}
    ],
    bubble: [
      {color:"#F5EBD9",position:0},
      {color:"#F2D4DB",position:.31},
      {color:"#EBBDDE",position:.5},
      {color:"#CCBAE3",position:.65},
      {color:"#8CBFF0",position:.82},
      {color:"#78B0FF",position:1}
    ],
    peach: [
      {color:"#D9F5FA",position:0},
      {color:"#FCD9D6",position:.31},
      {color:"#FCBAC9",position:.61},
      {color:"#F0B3F5",position:1}
    ],
    tonic: [
      {color:"#E3EDF0",position:0},
      {color:"#E8EBB8",position:.27},
      {color:"#F0DEA3",position:.43},
      {color:"#E8B078",position:.75},
      {color:"#F29682",position:1}
    ],
    mint: [
      {color:"#DECEE8",position:0},
      {color:"#CBBAEE",position:.21},
      {color:"#7DC0FB",position:.46},
      {color:"#00C7A6",position:1}
    ],
    spring: [
      {color:"#F7D5C5",position:.07},
      {color:"#46A8C0",position:.58},
      {color:"#43AE7D",position:1}
    ],
    twilight: [
      {color:"#E3CCE6",position:0},
      {color:"#4E8CD5",position:.35},
      {color:"#6068C2",position:.64},
      {color:"#38364E",position:1}
    ],
    bay: [
      {color:"#DBE3D0",position:0},
      {color:"#8DB8A7",position:.23},
      {color:"#2D8E9A",position:.42},
      {color:"#076492",position:.59},
      {color:"#154288",position:.79},
      {color:"#262C81",position:1}
    ]
  };

  const easings: Record<string, string> = {
    smooth: "cubic-bezier(0.25, 1, 0.5, 1)", // faster start ease-out/in-out hybrid
    gentle: "cubic-bezier(0.32, 0.72, 0, 1)", // iOS-like drawer curve (responsive, natural)
    snappy: "cubic-bezier(0.23, 1, 0.32, 1)", // strong ease-out (extremely responsive)
    linear: "linear",
  };

  function getGradientString(stops: GradientStop[], angle: number): string {
    const u = [...stops].sort((p, _) => p.position - _.position);
    const a = u[0]?.color ?? "white";
    const r = u[u.length - 1]?.color ?? "white";
    const o = u.map(p => {
      const _ = (p.position - 0.5) * 2 * lb;
      return `${p.color} calc(50% + var(--gs-spread-mid) * ${_.toFixed(4)})`;
    }).join(", ");
    return [
      `linear-gradient(${angle}deg`,
      "var(--gs-base) calc(50% - var(--gs-spread))",
      `color-mix(in oklab, var(--gs-base) 42%, ${a}) calc(50% - var(--gs-spread-mid))`,
      o,
      `color-mix(in oklab, var(--gs-base) 42%, ${r}) calc(50% + var(--gs-spread-mid))`,
      "var(--gs-base) calc(50% + var(--gs-spread)))"
    ].join(", ");
  }

  function initShimmers() {
    const shimmers = document.querySelectorAll("[data-gradient-shimmer]");
    shimmers.forEach((el) => {
      if (el.getAttribute("data-shimmer-initialized")) return;
      el.setAttribute("data-shimmer-initialized", "true");
      
      const text = el.textContent || "";
      const gradName = el.getAttribute("data-gradient") || "sunrise";
      const easeName = el.getAttribute("data-easing") || "smooth";
      const duration = parseFloat(el.getAttribute("data-duration") || "1.45");
      const spread = parseFloat(el.getAttribute("data-spread") || "3");
      const angle = parseFloat(el.getAttribute("data-angle") || "105");
      const stops = is[gradName] || is.sunrise;
      const gradientStr = getGradientString(stops, angle);
      const easing = easings[easeName] || easings.smooth;
      
      const element = el as HTMLElement;
      element.style.backgroundImage = "none";
      element.style.setProperty("--gs-base", "currentColor");
      
      const cb = 96;
      const rg = 48;
      const sg = 0.72;
      const fg = 14;

       const updateMetrics = () => {
        const width = element.getBoundingClientRect().width || cb;
        const height = element.getBoundingClientRect().height || 20;
        const fontSize = parseFloat(window.getComputedStyle(element).fontSize) || fg;
        const sizeRatio = fontSize / fg;
        const calculatedSpread = Math.min(text.length * spread * sizeRatio, rg * sizeRatio);
        const sizeX = Math.max(1, width + calculatedSpread * 2);
        const sizeY = Math.max(1, height + calculatedSpread * 2);
        
        // Adjust bounds to ensure the gradient begins and ends fully off-screen
        const spreadFactor = 0.7; // Start gradient closer to the text to eliminate starting delay
        const offset = 4 * sizeRatio;
        const startX = -calculatedSpread * spreadFactor - offset - sizeX / 2;
        const endX = width + calculatedSpread * spreadFactor + offset - sizeX / 2;
        
        const startY = -calculatedSpread * spreadFactor - offset - sizeY / 2;
        const endY = height + calculatedSpread * spreadFactor + offset - sizeY / 2;
        
        element.style.setProperty("--gs-spread", `${calculatedSpread}px`);
        element.style.setProperty("--gs-spread-mid", `${calculatedSpread * sg}px`);
        element.style.backgroundSize = `${sizeX}px ${sizeY}px`;
        
        return { startX, endX, startY, endY };
      };

      let anim: Animation | null = null;
      let isDestroyed = false;
      let isPaused = false;
      let isHovered = false;
      
      const startAnimation = () => {
        if (isDestroyed || !isHovered) return;
        const metrics = updateMetrics();
        const durationMs = duration * 1000;
        
        anim = element.animate([
          { backgroundPosition: `${metrics.startX}px ${metrics.startY}px` },
          { backgroundPosition: `${metrics.endX}px ${metrics.endY}px` }
        ], {
          duration: durationMs,
          easing: easing,
          iterations: 1,
          fill: "forwards"
        });
        
        if (isPaused) {
          anim.pause();
        }
      };
      
      // Pause animations when tab is inactive
      const handleVisibility = () => {
        if (document.hidden) {
          isPaused = true;
          if (anim) anim.pause();
        } else {
          isPaused = false;
          if (anim) anim.play();
        }
      };
      
      document.addEventListener("visibilitychange", handleVisibility);
      
      // Pause animations when element is offscreen
      let observer: IntersectionObserver | null = null;
      if ('IntersectionObserver' in window) {
        observer = new IntersectionObserver((entries) => {
          const entry = entries[entries.length - 1];
          if (entry) {
            if (entry.isIntersecting) {
              isPaused = false;
              if (anim) anim.play();
            } else {
              isPaused = true;
              if (anim) anim.pause();
            }
          }
        }, { rootMargin: "160px" });
        observer.observe(element);
      }

      const onMouseEnter = () => {
        isHovered = true;
        element.style.backgroundImage = gradientStr;
        startAnimation();
      };

      const onMouseLeave = () => {
        isHovered = false;
        if (anim) anim.cancel();
        element.style.backgroundImage = "none";
      };

      element.addEventListener("mouseenter", onMouseEnter);
      element.addEventListener("mouseleave", onMouseLeave);

      // Cleanup on page swap (for Astro View Transitions)
      document.addEventListener("astro:before-swap", () => {
        isDestroyed = true;
        if (anim) anim.cancel();
        element.removeEventListener("mouseenter", onMouseEnter);
        element.removeEventListener("mouseleave", onMouseLeave);
        document.removeEventListener("visibilitychange", handleVisibility);
        if (observer) observer.disconnect();
      });
      
      // Support prefers-reduced-motion
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (prefersReducedMotion) {
        // Reset to default static state (show gradient without animation, or fallback to current color)
        element.style.backgroundImage = gradientStr;
        element.style.backgroundSize = "100% 100%";
        element.style.backgroundPosition = "center";
        return;
      }
    });
  }

  // Initialize shimmers on page load/transition
  document.addEventListener("DOMContentLoaded", initShimmers);
  document.addEventListener("astro:page-load", initShimmers);
</script>
