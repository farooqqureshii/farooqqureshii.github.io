---
// Theme toggle - minimal filled circle that swaps color by mode
---

<button
  id="theme-toggle"
  class="theme-toggle-btn no-theme-transition flex h-5 w-5 items-center justify-center text-[#111111] dark:text-[#e4e4e7]"
  aria-label="Toggle theme"
  title="Toggle theme"
>
  <style>
    .toggle-dot {
      width: 16px;
      height: 16px;
      border-radius: 9999px;
      background: currentColor;
      transition: background-color 180ms ease;
    }
  </style>
  <span class="toggle-dot" aria-hidden="true"></span>
</button>

<script>
  let themeToggleSetup = false;

  function initThemeToggle() {
    if (themeToggleSetup) return;
    themeToggleSetup = true;

    document.addEventListener("click", function (e) {
      const target = e.target as HTMLElement | null;
      const toggle = target?.closest("#theme-toggle");
      if (!toggle) return;

      const html = document.documentElement;
      html.classList.add("theme-transition");
      const isDark = html.classList.contains("dark");

      if (isDark) {
        html.classList.remove("dark");
        localStorage.theme = "light";
      } else {
        html.classList.add("dark");
        localStorage.theme = "dark";
      }

      window.setTimeout(() => {
        html.classList.remove("theme-transition");
      }, 320);
    });
  }

  document.addEventListener("astro:page-load", initThemeToggle);
</script>
