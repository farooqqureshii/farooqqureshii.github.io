---
import HamburgerMenu from "./HamburgerMenu.astro";

const path = Astro.url.pathname;
const segment = path.split("/").filter(Boolean)[0];
const pageName = segment
  ? segment.charAt(0).toUpperCase() + segment.slice(1)
  : null;
---

<header class="mb-6 flex items-center justify-between">
  <div class="flex items-center gap-2 text-sm">
    <a href="/" class="nav-brand no-underline">Farooq Qureshi</a>
    {
      pageName && (
        <>
          <span class="text-zinc-500 dark:text-zinc-400">/</span>
          <a
            href={`/${segment}`}
            class="text-zinc-500 no-underline transition-colors hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-300"
          >
            {pageName}
          </a>
        </>
      )
    }
  </div>
  <div class="flex items-center gap-4">
    <button
      id="reset-annotations-btn"
      class="hidden items-center justify-center w-5 h-5 text-[#111111] hover:opacity-60 dark:text-[#e4e4e7] transition-all cursor-pointer"
      title="Reset text edits"
      aria-label="Reset text edits"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M3 3v5h5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
    <HamburgerMenu />
  </div>
</header>
