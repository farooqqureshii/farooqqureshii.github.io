---
import HamburgerMenu from "./HamburgerMenu.astro";

const path = Astro.url.pathname;
const segment = path.split("/").filter(Boolean)[0];
const pageName = segment
  ? segment.charAt(0).toUpperCase() + segment.slice(1)
  : null;
---

<header class="mb-6 flex items-center justify-between">
  <div class="flex items-center gap-2 text-sm">
    <a href="/" class="nav-brand no-underline">Farooq Qureshi</a>
    {
      pageName && (
        <>
          <span class="text-zinc-500 dark:text-zinc-400">/</span>
          <a
            href={`/${segment}`}
            class="text-zinc-500 no-underline transition-colors hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-300"
          >
            {pageName}
          </a>
        </>
      )
    }
  </div>
  <HamburgerMenu />
</header>
