---
import ThemeToggle from "./ThemeToggle.astro";

const path = Astro.url.pathname;
const segment = path.split("/").filter(Boolean)[0];
const pageName = segment ? segment.charAt(0).toUpperCase() + segment.slice(1) : null;
---

<header class="mb-12 flex items-center justify-between">
  <div class="flex items-center gap-2 text-sm">
    <a href="/" class="no-underline">Farooq Qureshi</a>
    {pageName && (
      <>
        <span class="text-zinc-500 dark:text-zinc-400">/</span>
        <a href={`/${segment}`} class="text-zinc-500 dark:text-zinc-400 no-underline hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors">{pageName}</a>
      </>
    )}
  </div>
  <div class="index-header-icons flex items-center gap-4">
    <span
      id="command-menu-button"
      class="command-menu-btn inline-flex items-center justify-center w-5 h-5 text-[#111111] dark:text-[#e4e4e7] cursor-pointer transition-transform duration-200 ease-out hover:scale-110 active:scale-95"
      title="Open command menu (⌘K)"
      aria-label="Open command menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        <path d="M2 12h20"/>
      </svg>
    </span>
    <ThemeToggle />
  </div>
</header>
