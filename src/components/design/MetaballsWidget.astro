---
// MetaballsWidget.astro - Liquid Metaball Typography
interface Props {
  showControls?: boolean;
}
const { showControls = false } = Astro.props;
---

<div class="metaballs-widget relative w-full flex flex-col md:flex-row bg-zinc-950 border border-zinc-800 rounded-xl overflow-hidden shadow-2xl select-none">
  <!-- Interactive canvas section -->
  <div class="flex-1 aspect-[16/10] sm:aspect-[16/9] relative min-h-[280px]">
    <!-- Blueprint grid background -->
    <div class="absolute inset-0 bg-[radial-gradient(#27272a_1px,transparent_1px)] [background-size:24px_24px] opacity-15 pointer-events-none"></div>

    <div class="metaball-filter-container absolute inset-0 flex items-center justify-center filter-contrast pointer-events-none">
      <canvas class="metaballs-canvas pointer-events-auto cursor-pointer filter-blur w-full h-full"></canvas>
    </div>

    <!-- Clear / overlay badges -->
    <div class="absolute bottom-4 left-4 z-20 pointer-events-none px-2.5 py-1 bg-zinc-900/80 backdrop-blur-md border border-zinc-800/80 rounded-full text-[9px] font-mono text-zinc-400 tracking-tight shadow-md">
      DRAG TO TEAR LIQUID FLUID
    </div>
  </div>

  <!-- Customization Panel sidebar -->
  {showControls && (
    <div class="w-full md:w-64 p-5 border-t md:border-t-0 md:border-l border-zinc-800 bg-zinc-950 text-zinc-200 flex flex-col gap-4.5 z-10 font-sans text-xs">
      <div class="font-semibold text-zinc-100 tracking-tight uppercase text-[10px] font-mono border-b border-zinc-800 pb-2">
        Fluid Playground
      </div>
      
      <label class="flex flex-col gap-1.5">
        <span class="text-[10px] text-zinc-400 font-mono uppercase">Render Text</span>
        <input type="text" class="word-input px-2 py-1.5 bg-zinc-900 border border-zinc-800 rounded text-zinc-100 outline-none focus:border-purple-500 font-mono" value="CRAFT" maxlength="10" />
      </label>

      <label class="flex flex-col gap-1">
        <div class="flex justify-between font-mono text-[10px] text-zinc-400">
          <span>VISCOSITY (BLUR)</span>
          <span class="viscosity-val">10px</span>
        </div>
        <input type="range" class="viscosity-slider w-full h-1 bg-zinc-800 rounded-lg appearance-none cursor-pointer accent-purple-500" min="4" max="20" value="10" />
      </label>

      <label class="flex flex-col gap-1">
        <div class="flex justify-between font-mono text-[10px] text-zinc-400">
          <span>ATTRACTION FORCE</span>
          <span class="attraction-val">0.12</span>
        </div>
        <input type="range" class="attraction-slider w-full h-1 bg-zinc-800 rounded-lg appearance-none cursor-pointer accent-purple-500" min="0.02" max="0.4" step="0.01" value="0.12" />
      </label>

      <label class="flex flex-col gap-1">
        <div class="flex justify-between font-mono text-[10px] text-zinc-400">
          <span>SPRING STIFFNESS</span>
          <span class="stiffness-val">0.12</span>
        </div>
        <input type="range" class="stiffness-slider w-full h-1 bg-zinc-800 rounded-lg appearance-none cursor-pointer accent-purple-500" min="0.03" max="0.3" step="0.01" value="0.12" />
      </label>

      <button type="button" class="reset-btn mt-2 w-full py-2 bg-zinc-900 border border-zinc-800 rounded hover:bg-zinc-800 text-zinc-300 font-mono font-medium active:scale-95 transition-all cursor-pointer">
        RE-INIT LIQUID
      </button>
    </div>
  )}
</div>

<style>
  .filter-contrast {
    filter: contrast(24) saturate(1.8);
    background: #09090b;
  }
  .filter-blur {
    filter: blur(var(--blur-px, 10px));
  }
  input[type="range"]::-webkit-slider-thumb {
    appearance: none;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #c084fc;
    cursor: pointer;
  }
</style>

<script src="/static/js/metaballs.js" is:inline></script>
