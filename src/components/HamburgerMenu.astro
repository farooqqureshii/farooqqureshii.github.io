---
// Full-page hamburger menu overlay
---

<!-- Hamburger trigger button -->
<button
  id="hamburger-btn"
  class="hamburger-btn"
  aria-label="Open menu"
  aria-expanded="false"
>
  <span class="h-bar"></span>
  <span class="h-bar"></span>
</button>

<style>
  .hamburger-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    color: inherit;
    position: relative;
    z-index: 1;
    transition:
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.12s ease;
  }

  /* When open, visually hide the hamburger and rotate it */
  .hamburger-btn[aria-expanded="true"] {
    pointer-events: none;
    opacity: 0.01;
    transform: scale(0.98) rotate(-45deg);
  }

  .h-bar {
    position: absolute;
    top: 50%;
    left: 50%;
    background: currentColor;
    border-radius: 2px;
    transition:
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.25s ease;
  }

  /* Horizontal bar of the + */
  .h-bar:nth-child(1) {
    width: 16px;
    height: 1.5px;
    transform: translate(-50%, -50%);
  }

  /* Vertical bar of the + */
  .h-bar:nth-child(2) {
    width: 1.5px;
    height: 16px;
    transform: translate(-50%, -50%);
  }
</style>

<script>
  let currentToggleHandler: ((e: Event) => void) | null = null;

  function initHamburger() {
    // If there's an existing handler from a previous page view, clean it up
    if (currentToggleHandler) {
      document.removeEventListener(
        "toggle-hamburger-menu",
        currentToggleHandler,
      );
      currentToggleHandler = null;
    }

    const btn = document.getElementById(
      "hamburger-btn",
    ) as HTMLButtonElement | null;
    if (!btn) return;

    // Clean up any existing overlay to prevent duplicates
    const existingOverlay = document.getElementById("menu-overlay");
    if (existingOverlay) {
      existingOverlay.remove();
    }

    const overlay = document.createElement("div");
    overlay.id = "menu-overlay";
    overlay.setAttribute("aria-hidden", "true");
    overlay.innerHTML = `
      <button id="menu-close" class="mo-close" aria-label="Close menu">
        <span class="mc-bar"></span>
        <span class="mc-bar"></span>
      </button>
      <div class="mo-inner flashlight-hover">
        <nav class="mo-nav">
          <a href="/projects" class="mo-link flashlight-item" data-s="1">Projects</a>
          <a href="/writing" class="mo-link flashlight-item" data-s="2">Writing</a>
          <a href="/artifacts" class="mo-link flashlight-item" data-s="3">Artifacts</a>
          <a href="/other" class="mo-link flashlight-item" data-s="4">Other</a>
          <a href="https://www.cosmos.so/farooqqureshi" target="_blank" rel="noopener" class="mo-link flashlight-item" data-s="5">Cosmos</a>
          <a href="https://linkedin.com/in/farooqq" target="_blank" rel="noopener" class="mo-link flashlight-item" data-s="6">LinkedIn</a>
          <a href="https://github.com/farooqqureshii" target="_blank" rel="noopener" class="mo-link flashlight-item" data-s="7">GitHub</a>
          <a href="mailto:farooq.qureshi@outlook.com" class="mo-link flashlight-item" data-s="8">Email</a>
        </nav>
        <div class="mo-actions">
          <button id="menu-theme-toggle" class="mo-action-btn flashlight-item" data-s="9"><span id="menu-theme-label">Dark</span></button>
          <button id="menu-sound-toggle" class="mo-action-btn flashlight-item" style="margin-top: 0.5rem;" data-s="10"><span id="menu-sound-label">Sound: On</span></button>
        </div>
      </div>
    `;

    // Avoid appending duplicate style tags to the head
    if (!document.getElementById("hamburger-menu-styles")) {
      const style = document.createElement("style");
      style.id = "hamburger-menu-styles";
      style.textContent = `
        #menu-overlay {
          position: fixed;
          inset: 0;
          z-index: 10000;
          background: #ffffff;
          color: #e4e4e7;
          display: flex;
          align-items: center;
          justify-content: center;
          opacity: 0;
          visibility: hidden;
          transition: opacity 0.12s ease, visibility 0s linear 0.12s;
        }
        html:not(.dark) #menu-overlay {
          color: #111111;
        }
        html.dark #menu-overlay {
          background: #1a1a1a;
        }
        #menu-overlay.open {
          opacity: 1;
          visibility: visible;
          transition: opacity 0.12s ease, visibility 0s linear 0s;
        }
        #menu-overlay.closing {
          opacity: 0;
          transition: opacity 0.2s cubic-bezier(0.23, 1, 0.32, 1) 0.04s, visibility 0s linear 0.24s;
        }

        /* Close X — positioned by JS to overlay the hamburger */
        .mo-close {
          position: fixed;
          width: 18px;
          height: 18px;
          display: flex;
          align-items: center;
          justify-content: center;
          background: transparent;
          border: none;
          cursor: pointer;
          padding: 0;
          z-index: 10001;
          outline: none !important;
          -webkit-tap-highlight-color: transparent !important;
          will-change: transform, opacity;
          backface-visibility: hidden;
          -webkit-backface-visibility: hidden;
          transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.12s ease;
        }
        .mc-bar {
          position: absolute;
          top: 50%;
          left: 50%;
          background: #111;
          border-radius: 2px;
          will-change: transform;
          backface-visibility: hidden;
          -webkit-backface-visibility: hidden;
          transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        html.dark .mc-bar { background: #e4e4e7; }
        
        .mo-close .mc-bar:nth-child(1) {
          width: 16px;
          height: 2px;
          transform: translate(-50%, -50%);
        }
        .mo-close .mc-bar:nth-child(2) {
          width: 2px;
          height: 16px;
          transform: translate(-50%, -50%);
        }
        .mo-close.active {
          transform: rotate(-45deg);
        }

        .mo-inner {
          width: 100%;
          max-width: 600px;
          padding: 2.5rem 2rem;
          display: flex;
          flex-direction: column;
          align-items: flex-start;
          gap: 2rem;
          transform: translateY(0) scale(1);
          opacity: 1;
          transition:
            transform 0.24s cubic-bezier(0.23, 1, 0.32, 1),
            opacity 0.2s cubic-bezier(0.23, 1, 0.32, 1);
        }
        .mo-nav {
          display: flex;
          flex-direction: column;
          gap: 0;
        }
        .mo-link {
          font-size: 2.25rem;
          font-weight: 400;
          letter-spacing: -0.03em;
          color: inherit;
          text-decoration: none;
          line-height: 1.35;
          opacity: 0;
          position: relative;
          will-change: opacity, transform;
          transform: translateY(6px);
          transition:
            opacity 0.18s cubic-bezier(0.23, 1, 0.32, 1),
            transform 0.18s cubic-bezier(0.23, 1, 0.32, 1);
        }
        .mo-link::after,
        .mo-action-btn::after {
          display: none !important;
        }

        /* Enter: one clean composed motion */
        #menu-overlay.open .mo-inner {
          transform: translateY(0) scale(1);
          opacity: 1;
        }
        #menu-overlay.open .mo-link,
        #menu-overlay.open .mo-action-btn {
          opacity: 1;
          transform: translateY(0);
        }

        #menu-overlay.closing .mo-inner {
          transform: translateY(8px) scale(0.988);
          opacity: 0;
        }
        #menu-overlay.closing .mo-link,
        #menu-overlay.closing .mo-action-btn {
          opacity: 0;
          transform: translateY(6px);
        }

        #menu-overlay:not(.open):not(.closing) .mo-link,
        #menu-overlay:not(.open):not(.closing) .mo-action-btn {
          opacity: 0 !important;
          animation: none !important;
          transform: translateY(6px) !important;
        }

        /* Flashlight effect overrides — ensure smooth opacity transition beats animation fill */
        .mo-inner.flashlight-hover .flashlight-item {
          transition: opacity 0.18s ease-out, transform 0.18s cubic-bezier(0.4, 0, 0.2, 1) !important;
        }
        .mo-inner.flashlight-hover.active .flashlight-item {
          opacity: 0.25 !important;
        }
        .mo-inner.flashlight-hover.active .flashlight-item.hovered {
          opacity: 1 !important;
          transform: translateX(6px) !important;
        }

        .mo-actions {
          display: flex;
          flex-direction: column;
          align-items: flex-start;
          gap: 0;
        }
        .mo-action-btn {
          background: transparent;
          border: none;
          cursor: pointer;
          color: inherit;
          font-size: 2.25rem;
          font-weight: 400;
          letter-spacing: -0.03em;
          font-family: inherit;
          padding: 0;
          line-height: 1.35;
          display: block;
          text-align: left;
          position: relative;
          opacity: 0;
          will-change: opacity, transform;
          transform: translateY(6px);
          transition:
            opacity 0.18s cubic-bezier(0.23, 1, 0.32, 1),
            transform 0.18s cubic-bezier(0.23, 1, 0.32, 1);
          -webkit-font-smoothing: antialiased;
        }
        #menu-theme-label,
        #menu-sound-label {
          display: inline-block;
          -webkit-transform: translateZ(0);
          transform: translateZ(0);
          will-change: opacity, transform;
          font-weight: 400;
          color: inherit;
          -webkit-font-smoothing: antialiased;
          text-rendering: optimizeLegibility;
        }
      `;
      document.head.appendChild(style);
    }

    document.body.appendChild(overlay);

    // Init flashlight effect for the menu nav
    const flashContainer = overlay.querySelector(
      ".mo-inner.flashlight-hover",
    ) as HTMLElement | null;
    if (flashContainer) {
      const flashItems = flashContainer.querySelectorAll(".flashlight-item");
      flashItems.forEach((item) => {
        item.addEventListener("mouseenter", () => {
          flashItems.forEach((el) => el.classList.remove("hovered"));
          item.classList.add("hovered");
          flashContainer.classList.add("active");
        });
      });
      flashContainer.addEventListener("mouseleave", () => {
        flashItems.forEach((el) => el.classList.remove("hovered"));
        flashContainer.classList.remove("active");
      });
    }

    // Place the X button exactly over the hamburger (restore JS positioning)
    function positionCloseBtn() {
      const closeBtn = overlay.querySelector(
        "#menu-close",
      ) as HTMLElement | null;
      if (!closeBtn || !btn) return;

      // Temporarily strip transform by toggling aria-expanded to get clean layout bounds
      const isExpanded = btn.getAttribute("aria-expanded") === "true";
      if (isExpanded) {
        btn.setAttribute("aria-expanded", "false");
      }

      const r = btn.getBoundingClientRect();

      if (isExpanded) {
        btn.setAttribute("aria-expanded", "true");
      }

      // position: fixed uses viewport coordinates, so r.top/left are correct
      closeBtn.style.top = r.top + "px";
      closeBtn.style.left = r.left + "px";
    }

    function toggleTheme() {
      const html = document.documentElement;
      html.classList.add("theme-transition");
      const isDark = html.classList.contains("dark");
      if (isDark) {
        html.classList.remove("dark");
        localStorage.theme = "light";
      } else {
        html.classList.add("dark");
        localStorage.theme = "dark";
      }
      setTimeout(() => html.classList.remove("theme-transition"), 320);
      updateThemeLabel();
    }

    function updateThemeLabel() {
      const label = document.getElementById("menu-theme-label");
      if (!label) return;
      label.textContent = document.documentElement.classList.contains("dark")
        ? "Light"
        : "Dark";
    }

    function toggleSound() {
      const isMuted = localStorage.sound === "off";
      if (isMuted) {
        localStorage.sound = "on";
      } else {
        localStorage.sound = "off";
      }
      updateSoundLabel();
      window.dispatchEvent(new CustomEvent("sound-toggled"));
    }

    function updateSoundLabel() {
      const label = document.getElementById("menu-sound-label");
      if (!label) return;
      label.textContent =
        localStorage.sound === "off" ? "Sound: Off" : "Sound: On";
    }

    const menuEls = () =>
      overlay.querySelectorAll<HTMLElement>(".mo-link, .mo-action-btn");

    // Dynamic global listener cleanup/setup to prevent memory leaks and duplicate listeners
    const handleKeyDown = (e: KeyboardEvent) => {
      if (e.key === "Escape") closeMenu();
    };

    const handleResize = () => {
      requestAnimationFrame(() => positionCloseBtn());
    };

    const handleOrientation = () => {
      requestAnimationFrame(() => positionCloseBtn());
    };

    function cleanupGlobalListeners() {
      document.removeEventListener("keydown", handleKeyDown);
      window.removeEventListener("resize", handleResize);
      window.removeEventListener("orientationchange", handleOrientation);
      document.removeEventListener("astro:before-swap", cleanupGlobalListeners);
    }

    function openMenu() {
      // Position the close button synchronously before we apply any transformation
      positionCloseBtn();

      updateThemeLabel();
      updateSoundLabel();
      // Clear any inline overrides from a previous session and apply stagger delays
      menuEls().forEach((el, index) => {
        el.style.removeProperty("animation");
        el.style.removeProperty("opacity");
        el.style.removeProperty("transform");
        el.style.transitionDelay = `${index * 30}ms`;
      });
      // Prevent layout shift by locking scroll and compensating for scrollbar width
      const scrollBarComp =
        window.innerWidth - document.documentElement.clientWidth;
      if (scrollBarComp > 0)
        document.body.style.paddingRight = scrollBarComp + "px";
      document.body.style.overflow = "hidden";
      overlay.classList.remove("closing");
      overlay.classList.add("open");

      // Add global listeners when menu is opened
      document.addEventListener("keydown", handleKeyDown);
      window.addEventListener("resize", handleResize);
      window.addEventListener("orientationchange", handleOrientation);
      document.addEventListener("astro:before-swap", cleanupGlobalListeners);

      // After the menu settles, strip inline animation fill so hover transitions work freely
      setTimeout(() => {
        menuEls().forEach((el) => {
          el.style.opacity = "1";
          el.style.transform = "none";
          el.style.animation = "none";
          el.style.removeProperty("transition-delay");
        });
      }, 550);
      btn?.setAttribute("aria-expanded", "true");
      overlay.setAttribute("aria-hidden", "false");
      // Animate X button bars from horizontal → X (ensure positioned first)
      const closeBtn = overlay.querySelector("#menu-close");
      closeBtn?.classList.remove("reversing");
      requestAnimationFrame(() => closeBtn?.classList.add("active"));
    }

    function closeMenu() {
      if (!overlay.classList.contains("open")) return;

      // Step 1: animate X bars back to horizontal
      const closeBtn = overlay.querySelector("#menu-close");
      closeBtn?.classList.remove("active");

      // Step 2: start a single clean exit transition
      menuEls().forEach((el) => {
        el.style.opacity = "1";
        el.style.transform = "none";
      });
      // Reset flashlight state before animating out
      if (flashContainer) {
        flashContainer
          .querySelectorAll(".flashlight-item")
          .forEach((el) => el.classList.remove("hovered"));
        flashContainer.classList.remove("active");
      }
      overlay.classList.add("closing");
      overlay.classList.remove("open");
      btn?.setAttribute("aria-expanded", "false");
      overlay.setAttribute("aria-hidden", "true");

      // Clean up global listeners when menu is closed
      cleanupGlobalListeners();

      // Step 3: cleanup once the panel transition has finished
      setTimeout(() => {
        overlay.classList.remove("closing");
        document.body.style.overflow = "";
        document.body.style.paddingRight = "";
        menuEls().forEach((el) => {
          el.style.removeProperty("transition-delay");
        });
      }, 300);
    }

    btn.addEventListener("click", () => {
      overlay.classList.contains("open") ? closeMenu() : openMenu();
    });

    overlay.querySelector("#menu-close")?.addEventListener("click", closeMenu);
    // Close when clicking the overlay backdrop (outside the inner menu)
    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) closeMenu();
    });
    overlay
      .querySelectorAll(".mo-link")
      .forEach((l) => l.addEventListener("click", closeMenu));
    overlay
      .querySelector("#menu-theme-toggle")
      ?.addEventListener("click", toggleTheme);
    overlay
      .querySelector("#menu-sound-toggle")
      ?.addEventListener("click", toggleSound);

    // Set up custom event trigger handler for the hamburger menu
    currentToggleHandler = (e: Event) => {
      const customEvent = e as CustomEvent<{
        action?: "open" | "close" | "toggle";
      }>;
      const action = customEvent.detail?.action;
      if (action === "open") {
        openMenu();
      } else if (action === "close") {
        closeMenu();
      } else {
        overlay.classList.contains("open") ? closeMenu() : openMenu();
      }
    };
    document.addEventListener("toggle-hamburger-menu", currentToggleHandler);
  }

  // Use defensive readyState check to ensure init runs immediately if DOMContentLoaded has already fired
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHamburger);
  } else {
    initHamburger();
  }
  // Support Astro view transitions
  document.addEventListener("astro:after-swap", initHamburger);
</script>
