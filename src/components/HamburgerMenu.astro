---
// Full-page hamburger menu overlay
---

<!-- Hamburger trigger button -->
<button
  id="hamburger-btn"
  class="hamburger-btn"
  aria-label="Open menu"
  aria-expanded="false"
>
  <span class="h-bar"></span>
  <span class="h-bar"></span>
</button>

<style>
  .hamburger-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 20px;
    height: 20px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    color: inherit;
    position: relative;
    z-index: 1;
    transition: opacity 0.12s ease;
  }

  .hamburger-btn[aria-expanded="true"] {
    pointer-events: none;
    opacity: 0;
  }

  .h-bar {
    display: block;
    width: 18px;
    height: 1.5px;
    background: currentColor;
    border-radius: 2px;
    transition:
      transform 0.12s ease,
      opacity 0.12s ease;
    transform-origin: center;
  }

  .hamburger-btn[aria-expanded="true"] .h-bar:nth-child(1) {
    transform: translateY(3.25px) rotate(45deg);
  }
  .hamburger-btn[aria-expanded="true"] .h-bar:nth-child(2) {
    transform: translateY(-3.25px) rotate(-45deg);
  }
</style>

<script>
  function initHamburger() {
    const btn = document.getElementById(
      "hamburger-btn",
    ) as HTMLButtonElement | null;
    if (!btn) return;

    const overlay = document.createElement("div");
    overlay.id = "menu-overlay";
    overlay.setAttribute("aria-hidden", "true");
    overlay.innerHTML = `
      <button id="menu-close" class="mo-close" aria-label="Close menu">
        <span class="mc-bar"></span>
        <span class="mc-bar"></span>
      </button>
      <div class="mo-inner flashlight-hover">
        <nav class="mo-nav">
          <a href="/projects" class="mo-link flashlight-item" data-s="1">Projects</a>
          <a href="/writing" class="mo-link flashlight-item" data-s="2">Writing</a>
          <a href="/artifacts" class="mo-link flashlight-item" data-s="3">Artifacts</a>
          <a href="/other" class="mo-link flashlight-item" data-s="4">Other</a>
          <a href="https://www.cosmos.so/farooqqureshi" target="_blank" rel="noopener" class="mo-link flashlight-item" data-s="5">Cosmos</a>
          <a href="https://linkedin.com/in/farooqq" target="_blank" rel="noopener" class="mo-link flashlight-item" data-s="6">LinkedIn</a>
          <a href="https://github.com/farooqqureshii" target="_blank" rel="noopener" class="mo-link flashlight-item" data-s="7">GitHub</a>
          <a href="mailto:farooq.qureshi@outlook.com" class="mo-link flashlight-item" data-s="8">Email</a>
        </nav>
        <div class="mo-actions flashlight-item" data-s="9">
          <button id="menu-theme-toggle" class="mo-action-btn"><span id="menu-theme-label">Dark</span></button>
        </div>
      </div>
    `;

    const style = document.createElement("style");
    style.textContent = `
      #menu-overlay {
        position: fixed;
        inset: 0;
        z-index: 10000;
        background: #0a0a0a;
        color: #e4e4e7;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.12s ease, visibility 0s linear 0.12s;
      }
      html:not(.dark) #menu-overlay {
        background: #f5f5f5;
        color: #111111;
      }
      #menu-overlay.open {
        opacity: 1;
        visibility: visible;
        transition: opacity 0.12s ease, visibility 0s linear 0s;
      }
      /* Fade overlay out right as items finish exiting */
      #menu-overlay.closing {
        opacity: 0;
        transition: opacity 0.12s ease 0.08s, visibility 0s linear 0.22s;
      }

      /* Close X — positioned over the hamburger via JS */
      .mo-close {
        position: fixed;
        width: 20px;
        height: 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 5px;
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0;
        z-index: 10001;
      }
      .mc-bar {
        display: block;
        width: 18px;
        height: 1.5px;
        background: #111;
        border-radius: 2px;
        transform-origin: center;
        transition: transform 0.15s ease;
      }
      html.dark .mc-bar { background: #e4e4e7; }
      /* Bars start horizontal, animate to X when active */
      .mo-close.active .mc-bar:nth-child(1) { transform: translateY(3.25px) rotate(45deg); }
      .mo-close.active .mc-bar:nth-child(2) { transform: translateY(-3.25px) rotate(-45deg); }

      .mo-inner {
        width: 100%;
        max-width: 600px;
        padding: 2.5rem 2rem;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 2rem;
      }
      .mo-nav {
        display: flex;
        flex-direction: column;
        gap: 0;
      }
      .mo-link {
        font-size: 2.25rem;
        font-weight: 400;
        letter-spacing: -0.03em;
        color: inherit;
        text-decoration: none;
        line-height: 1.35;
        opacity: 0;
        transform: translateY(8px);
        position: relative;
      }
      .mo-link::after,
      .mo-action-btn::after {
        display: none !important;
      }

      /* Enter: top-to-bottom stagger, slide up */
      #menu-overlay.open .mo-link[data-s="1"]    { animation: moIn 0.14s cubic-bezier(0.34,1.56,0.64,1) 20ms  forwards; }
      #menu-overlay.open .mo-link[data-s="2"]    { animation: moIn 0.14s cubic-bezier(0.34,1.56,0.64,1) 38ms  forwards; }
      #menu-overlay.open .mo-link[data-s="3"]    { animation: moIn 0.14s cubic-bezier(0.34,1.56,0.64,1) 56ms  forwards; }
      #menu-overlay.open .mo-link[data-s="4"]    { animation: moIn 0.14s cubic-bezier(0.34,1.56,0.64,1) 74ms  forwards; }
      #menu-overlay.open .mo-link[data-s="5"]    { animation: moIn 0.14s cubic-bezier(0.34,1.56,0.64,1) 92ms  forwards; }
      #menu-overlay.open .mo-link[data-s="6"]    { animation: moIn 0.14s cubic-bezier(0.34,1.56,0.64,1) 110ms forwards; }
      #menu-overlay.open .mo-link[data-s="7"]    { animation: moIn 0.14s cubic-bezier(0.34,1.56,0.64,1) 128ms forwards; }
      #menu-overlay.open .mo-link[data-s="8"]    { animation: moIn 0.14s cubic-bezier(0.34,1.56,0.64,1) 146ms forwards; }
      #menu-overlay.open .mo-actions[data-s="9"] { animation: moIn 0.14s cubic-bezier(0.34,1.56,0.64,1) 164ms forwards; }

      /* Exit: all items out together, fast */
      #menu-overlay.closing .mo-link,
      #menu-overlay.closing .mo-actions { animation: moOut 0.1s ease-in forwards !important; }

      #menu-overlay:not(.open):not(.closing) .mo-link,
      #menu-overlay:not(.open):not(.closing) .mo-actions {
        opacity: 0 !important;
        transform: translateY(8px);
        animation: none !important;
      }

      @keyframes moIn {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes moOut {
        from { opacity: 1; transform: translateY(0); }
        to   { opacity: 0; transform: translateY(8px); }
      }

      /* Flashlight effect overrides — ensure smooth opacity transition beats animation fill */
      .mo-inner.flashlight-hover .flashlight-item {
        transition: opacity 0.18s ease-out, transform 0.18s cubic-bezier(0.4, 0, 0.2, 1) !important;
      }
      .mo-inner.flashlight-hover.active .flashlight-item {
        opacity: 0.25 !important;
      }
      .mo-inner.flashlight-hover.active .flashlight-item.hovered {
        opacity: 1 !important;
        transform: translateX(6px) !important;
      }

      .mo-actions {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0;
        opacity: 0;
        transform: translateY(8px);
      }
      .mo-action-btn {
        background: transparent;
        border: none;
        cursor: pointer;
        color: inherit;
        font-size: 2.25rem;
        font-weight: 400;
        letter-spacing: -0.03em;
        font-family: inherit;
        padding: 0;
        line-height: 1.35;
        display: block;
        text-align: left;
        position: relative;
      }
    `;

    document.head.appendChild(style);
    document.body.appendChild(overlay);

    // Init flashlight effect for the menu nav
    const flashContainer = overlay.querySelector(
      ".mo-inner.flashlight-hover",
    ) as HTMLElement | null;
    if (flashContainer) {
      const flashItems = flashContainer.querySelectorAll(".flashlight-item");
      flashItems.forEach((item) => {
        item.addEventListener("mouseenter", () => {
          flashItems.forEach((el) => el.classList.remove("hovered"));
          item.classList.add("hovered");
          flashContainer.classList.add("active");
        });
      });
      flashContainer.addEventListener("mouseleave", () => {
        flashItems.forEach((el) => el.classList.remove("hovered"));
        flashContainer.classList.remove("active");
      });
    }

    // Place the X button exactly over the hamburger
    function positionCloseBtn() {
      const closeBtn = overlay.querySelector(
        "#menu-close",
      ) as HTMLElement | null;
      if (!closeBtn || !btn) return;
      const r = btn.getBoundingClientRect();
      closeBtn.style.top = r.top + "px";
      closeBtn.style.left = r.left + "px";
    }

    function toggleTheme() {
      const html = document.documentElement;
      html.classList.add("theme-transition");
      const isDark = html.classList.contains("dark");
      if (isDark) {
        html.classList.remove("dark");
        localStorage.theme = "light";
      } else {
        html.classList.add("dark");
        localStorage.theme = "dark";
      }
      setTimeout(() => html.classList.remove("theme-transition"), 320);
      updateThemeLabel();
    }

    function updateThemeLabel() {
      const label = document.getElementById("menu-theme-label");
      if (!label) return;
      label.textContent = document.documentElement.classList.contains("dark")
        ? "Light"
        : "Dark";
    }

    const menuEls = () =>
      overlay.querySelectorAll<HTMLElement>(".mo-link, .mo-actions");

    function openMenu() {
      updateThemeLabel();
      // Clear any inline overrides from a previous session so CSS animations re-run cleanly
      menuEls().forEach((el) => {
        el.style.removeProperty("animation");
        el.style.removeProperty("opacity");
        el.style.removeProperty("transform");
      });
      // Prevent layout shift by locking scroll and compensating for scrollbar width
      const scrollBarComp = window.innerWidth - document.documentElement.clientWidth;
      if (scrollBarComp > 0) document.body.style.paddingRight = scrollBarComp + "px";
      document.body.style.overflow = "hidden";
      overlay.classList.remove("closing");
      overlay.classList.add("open");
      // Position close button after overflow change has taken effect
      requestAnimationFrame(() => positionCloseBtn());
      // After the last entrance animation finishes (164ms delay + 140ms = ~310ms),
      // strip animation fill so flashlight opacity/transform transitions work freely
      setTimeout(() => {
        menuEls().forEach((el) => {
          el.style.opacity = "1";
          el.style.transform = "none";
          el.style.animation = "none";
        });
      }, 320);
      btn?.setAttribute("aria-expanded", "true");
      overlay.setAttribute("aria-hidden", "false");
      // Animate X button bars from horizontal → X (ensure positioned first)
      const closeBtn = overlay.querySelector("#menu-close");
      closeBtn?.classList.remove("reversing");
      requestAnimationFrame(() => closeBtn?.classList.add("active"));
    }

    function closeMenu() {
      if (!overlay.classList.contains("open")) return;

      // Step 1: animate X bars back to horizontal
      const closeBtn = overlay.querySelector("#menu-close");
      closeBtn?.classList.remove("active");

      // Step 2: simultaneously start content exit
      // Restore items to a known state so the CSS closing animation can fire
      menuEls().forEach((el) => {
        el.style.removeProperty("animation");
        el.style.opacity = "1";
        el.style.transform = "none";
      });
      // Reset flashlight state before animating out
      if (flashContainer) {
        flashContainer
          .querySelectorAll(".flashlight-item")
          .forEach((el) => el.classList.remove("hovered"));
        flashContainer.classList.remove("active");
      }
      overlay.classList.add("closing");
      overlay.classList.remove("open");
      btn?.setAttribute("aria-expanded", "false");
      overlay.setAttribute("aria-hidden", "true");

      // Step 3: cleanup
      setTimeout(() => {
        overlay.classList.remove("closing");
        document.body.style.overflow = "";
        document.body.style.paddingRight = "";
      }, 240);
    }

    btn.addEventListener("click", () => {
      overlay.classList.contains("open") ? closeMenu() : openMenu();
    });

    overlay.querySelector("#menu-close")?.addEventListener("click", closeMenu);
    // Close when clicking the overlay backdrop (outside the inner menu)
    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) closeMenu();
    });
    overlay
      .querySelectorAll(".mo-link")
      .forEach((l) => l.addEventListener("click", closeMenu));
    overlay
      .querySelector("#menu-theme-toggle")
      ?.addEventListener("click", toggleTheme);

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && overlay.classList.contains("open")) closeMenu();
    });
    // Reposition the close button if viewport changes while open (orientation/resize)
    window.addEventListener("resize", () => {
      if (overlay.classList.contains("open")) requestAnimationFrame(() => positionCloseBtn());
    });
    window.addEventListener("orientationchange", () => {
      if (overlay.classList.contains("open")) requestAnimationFrame(() => positionCloseBtn());
    });
  }

  document.addEventListener("DOMContentLoaded", initHamburger);
</script>
