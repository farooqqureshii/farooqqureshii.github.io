<footer class="mt-12 relative">
  <div class="flex items-center gap-1.5 text-sm text-zinc-500 dark:text-zinc-400">
    <span id="ottawa-time">--:--:--</span>
    <span>in Ottawa, Ontario</span>
  </div>
</footer>

<script>
  function updateOttawaTime() {
    const ottawaTime = new Date().toLocaleTimeString('en-CA', {
      timeZone: 'America/Toronto',
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      hour12: false
    });
    const timeEl = document.getElementById('ottawa-time');
    if (timeEl) {
      timeEl.textContent = ottawaTime;
    }
  }
  function initFooter() {
    updateOttawaTime();
    setInterval(updateOttawaTime, 1000);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFooter);
  } else {
    initFooter();
  }
</script>
