<script>
  const OTTAWA = { lat: 45.4215, lon: -75.6972 };
  const WEATHER_URL = `https://api.open-meteo.com/v1/forecast?latitude=${OTTAWA.lat}&longitude=${OTTAWA.lon}&current=temperature_2m&timezone=America%2FToronto`;

  function updateTime() {
    const t = new Date().toLocaleTimeString("en-CA", {
      timeZone: "America/Toronto",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: false,
    });
    const el = document.getElementById("ottawa-time");
    if (el) el.textContent = t;
  }

  async function updateWeather() {
    const el = document.getElementById("ottawa-weather");
    if (!el) return;
    try {
      const res = await fetch(WEATHER_URL);
      if (!res.ok) throw new Error();
      const data = await res.json();
      const t = Math.round(data.current.temperature_2m);
      el.textContent = `${t}°C`;
    } catch {
      el.textContent = "—°C";
    }
  }

  function initFooterGameOfLife(canvas: HTMLCanvasElement) {
    const context = canvas.getContext("2d", { alpha: true });
    if (!context) return null;
    const ctx: CanvasRenderingContext2D = context;

    const cellSize = 8;
    const gap = 1;
    const cellRadius = 1.5;
    const density = 0.32;
    const stepInterval = 140;
    const fadeDuration = 220;
    const maxOpacity = 0.16;

    let animationFrameId = 0;
    let columns = 0;
    let rows = 0;
    let grid = new Uint8Array(0);
    let nextGrid = new Uint8Array(0);
    let opacities = new Float32Array(0);
    let lastFrameTime = 0;
    let lastSimulationTime = 0;
    let fillColor = "";
    let isVisible = false;
    let stopTimeout: any = null;

    // Gather state variables
    let isGathering = false;
    let gatherStartTime = 0;
    let gatheringParticles: any[] = [];
    const gatherDuration = 350;

    const svg = canvas.closest("footer")?.querySelector("#footer-svg-icon") as HTMLElement | null;

    const drawSize = Math.max(1, cellSize - gap);

    function resolveFillColor() {
      const computedStyle = window.getComputedStyle(canvas);
      return computedStyle.color || "rgb(120, 128, 138)";
    }

    function resizeGrid(width: number, height: number) {
      const nextColumns = Math.max(1, Math.ceil(width / cellSize));
      const nextRows = Math.max(1, Math.ceil(height / cellSize));
      if (nextColumns === columns && nextRows === rows) return;

      const resizedGrid = new Uint8Array(nextColumns * nextRows);
      const resizedOpacities = new Float32Array(nextColumns * nextRows);

      for (let r = 0; r < nextRows; r++) {
        for (let c = 0; c < nextColumns; c++) {
          const nextIdx = r * nextColumns + c;
          if (c < columns && r < rows) {
            const currentIdx = r * columns + c;
            resizedGrid[nextIdx] = grid[currentIdx] || 0;
            resizedOpacities[nextIdx] = opacities[currentIdx] || 0;
          } else {
            resizedGrid[nextIdx] = Math.random() < density ? 1 : 0;
            resizedOpacities[nextIdx] = resizedGrid[nextIdx];
          }
        }
      }
      columns = nextColumns;
      rows = nextRows;
      grid = resizedGrid;
      nextGrid = new Uint8Array(resizedGrid.length);
      opacities = resizedOpacities;
    }

    function stepSimulation() {
      if (columns === 0 || rows === 0) return;
      for (let r = 0; r < rows; r++) {
        const rAbove = r === 0 ? rows - 1 : r - 1;
        const rBelow = r === rows - 1 ? 0 : r + 1;
        for (let c = 0; c < columns; c++) {
          const cLeft = c === 0 ? columns - 1 : c - 1;
          const cRight = c === columns - 1 ? 0 : c + 1;
          const idx = r * columns + c;
          const liveNeighbors =
            grid[rAbove * columns + cLeft] +
            grid[rAbove * columns + c] +
            grid[rAbove * columns + cRight] +
            grid[r * columns + cLeft] +
            grid[r * columns + cRight] +
            grid[rBelow * columns + cLeft] +
            grid[rBelow * columns + c] +
            grid[rBelow * columns + cRight];

          nextGrid[idx] =
            grid[idx] === 1
              ? (liveNeighbors === 2 || liveNeighbors === 3 ? 1 : 0)
              : (liveNeighbors === 3 ? 1 : 0);
        }
      }
      const temp = grid;
      grid = nextGrid;
      nextGrid = temp;
    }

    function updateOpacities(deltaTime: number) {
      const change = deltaTime / fadeDuration;
      for (let idx = 0; idx < opacities.length; idx++) {
        const target = grid[idx] || 0;
        const current = opacities[idx] || 0;
        if (current < target) {
          opacities[idx] = Math.min(target, current + change);
        } else if (current > target) {
          opacities[idx] = Math.max(target, current - change);
        }
      }
    }

    function injectNoise() {
      const total = grid.length;
      if (total === 0) return;

      if (rows < 4 || columns < 4) {
        const numToSpawn = Math.max(1, Math.floor(total * 0.12));
        for (let i = 0; i < numToSpawn; i++) {
          const idx = Math.floor(Math.random() * total);
          grid[idx] = 1;
          opacities[idx] = Math.max(opacities[idx], 0.8);
        }
        return;
      }

      const r = Math.floor(Math.random() * (rows - 3));
      const c = Math.floor(Math.random() * (columns - 3));
      const shapeIdx = Math.floor(Math.random() * 3);

      if (shapeIdx === 0) {
        // Glider
        const rot = Math.floor(Math.random() * 4);
        const gliders = [
          [[0, 1], [1, 2], [2, 0], [2, 1], [2, 2]],
          [[0, 1], [1, 0], [2, 0], [2, 1], [2, 2]],
          [[0, 1], [1, 2], [2, 2], [2, 1], [2, 0]],
          [[0, 1], [1, 0], [2, 2], [2, 1], [2, 0]]
        ];
        const shape = gliders[rot];
        for (const [dr, dc] of shape) {
          const idx = (r + dr) * columns + (c + dc);
          if (idx >= 0 && idx < total) {
            grid[idx] = 1;
            opacities[idx] = Math.max(opacities[idx], 0.8);
          }
        }
      } else if (shapeIdx === 1) {
        // Blinker (oscillator)
        const rot = Math.random() < 0.5;
        const shape = rot ? [[0, 1], [1, 1], [2, 1]] : [[1, 0], [1, 1], [1, 2]];
        for (const [dr, dc] of shape) {
          const idx = (r + dr) * columns + (c + dc);
          if (idx >= 0 && idx < total) {
            grid[idx] = 1;
            opacities[idx] = Math.max(opacities[idx], 0.8);
          }
        }
      } else {
        // Beacon (oscillator)
        const shape = [[0, 0], [0, 1], [1, 0], [1, 1], [2, 2], [2, 3], [3, 2], [3, 3]];
        for (const [dr, dc] of shape) {
          const idx = ((r + dr) % rows) * columns + ((c + dc) % columns);
          if (idx >= 0 && idx < total) {
            grid[idx] = 1;
            opacities[idx] = Math.max(opacities[idx], 0.8);
          }
        }
      }
    }

    function getSVGTargets() {
      if (!svg) return [];
      const rects = svg.querySelectorAll("rect");
      const canvasRect = canvas.getBoundingClientRect();
      return Array.from(rects).map((rect) => {
        const rectRect = rect.getBoundingClientRect();
        return {
          x: rectRect.left - canvasRect.left + rectRect.width / 2,
          y: rectRect.top - canvasRect.top + rectRect.height / 2,
        };
      });
    }

    function draw() {
      const dpr = Math.min(2, window.devicePixelRatio || 1);
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.fillStyle = fillColor;

      let idx = 0;
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < columns; c++) {
          const opacity = opacities[idx] || 0;
          if (opacity > 0.001) {
            ctx.globalAlpha = opacity * maxOpacity;
            const x = c * cellSize;
            const y = r * cellSize;
            const radius = Math.min(cellRadius, drawSize / 2);
            if (radius > 0 && "roundRect" in ctx) {
              ctx.beginPath();
              ctx.roundRect(x, y, drawSize, drawSize, radius);
              ctx.fill();
            } else {
              ctx.fillRect(x, y, drawSize, drawSize);
            }
          }
          idx++;
        }
      }
      ctx.globalAlpha = 1;
    }

    function drawGathering(t: number) {
      const dpr = Math.min(2, window.devicePixelRatio || 1);
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.fillStyle = fillColor;

      // 1. Draw other fading out cells
      let idx = 0;
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < columns; c++) {
          const opacity = opacities[idx] || 0;
          if (opacity > 0.001) {
            ctx.globalAlpha = opacity * maxOpacity * (1 - t);
            const x = c * cellSize;
            const y = r * cellSize;
            const radius = Math.min(cellRadius, drawSize / 2);
            if (radius > 0 && "roundRect" in ctx) {
              ctx.beginPath();
              ctx.roundRect(x, y, drawSize, drawSize, radius);
              ctx.fill();
            } else {
              ctx.fillRect(x, y, drawSize, drawSize);
            }
          }
          idx++;
        }
      }

      // 2. Draw the gathering particles
      ctx.globalAlpha = maxOpacity + (0.6 - maxOpacity) * t;
      for (const p of gatheringParticles) {
        const px = p.startX + (p.targetX - p.startX) * t;
        const py = p.startY + (p.targetY - p.startY) * t;
        const x = px - drawSize / 2;
        const y = py - drawSize / 2;
        const radius = Math.min(cellRadius, drawSize / 2);
        if (radius > 0 && "roundRect" in ctx) {
          ctx.beginPath();
          ctx.roundRect(x, y, drawSize, drawSize, radius);
          ctx.fill();
        } else {
          ctx.fillRect(x, y, drawSize, drawSize);
        }
      }
      ctx.globalAlpha = 1;
    }

    function resizeCanvas(width: number, height: number) {
      const cssWidth = Math.max(1, Math.floor(width));
      const cssHeight = Math.max(1, Math.floor(height));
      const dpr = Math.min(2, window.devicePixelRatio || 1);
      const canvasWidth = Math.max(1, Math.floor(cssWidth * dpr));
      const canvasHeight = Math.max(1, Math.floor(cssHeight * dpr));
      if (canvas.width !== canvasWidth || canvas.height !== canvasHeight) {
        canvas.width = canvasWidth;
        canvas.height = canvasHeight;
      }
      resizeGrid(cssWidth, cssHeight);
      fillColor = resolveFillColor();
      if (!isGathering) {
        draw();
      }
    }

    function loop(time: number) {
      if (!isVisible) {
        animationFrameId = 0;
        return;
      }
      if (!lastFrameTime) {
        lastFrameTime = time;
        lastSimulationTime = time;
      }
      const deltaTime = Math.min(100, time - lastFrameTime);
      lastFrameTime = time;

      if (isGathering) {
        const progress = Math.min(1, (time - gatherStartTime) / gatherDuration);
        const t = 1 - Math.pow(1 - progress, 3); // ease-out cubic

        updateOpacities(deltaTime);
        drawGathering(t);

        if (progress >= 1) {
          isGathering = false;
          isVisible = false;
          stopLoop();
          return;
        }
      } else {
        if (time - lastSimulationTime >= stepInterval) {
          stepSimulation();

          // Maintain density
          let liveCount = 0;
          for (let i = 0; i < grid.length; i++) {
            if (grid[i] === 1) liveCount++;
          }
          const densityVal = liveCount / (grid.length || 1);
          if (densityVal < 0.08) {
            injectNoise();
          }

          lastSimulationTime = time;
        }
        updateOpacities(deltaTime);
        draw();
      }
      animationFrameId = window.requestAnimationFrame(loop);
    }

    function startLoop() {
      if (animationFrameId || !isVisible) return;
      lastFrameTime = 0;
      lastSimulationTime = 0;
      animationFrameId = window.requestAnimationFrame(loop);
    }

    function stopLoop() {
      if (animationFrameId) {
        window.cancelAnimationFrame(animationFrameId);
        animationFrameId = 0;
      }
    }

    const resizeObserver = new ResizeObserver((entries) => {
      const entry = entries[0];
      if (!entry) return;
      resizeCanvas(entry.contentRect.width, entry.contentRect.height);
      startLoop();
    });
    resizeObserver.observe(canvas);

    const observer = new MutationObserver(() => {
      fillColor = resolveFillColor();
      if (!isGathering) {
        draw();
      }
    });
    observer.observe(document.documentElement, { attributeFilter: ["class", "style"] });

    return {
      start: () => {
        if (stopTimeout) {
          clearTimeout(stopTimeout);
          stopTimeout = null;
        }

        // Handle re-entering mid-gather
        if (isGathering) {
          isGathering = false;
          const elapsed = performance.now() - gatherStartTime;
          const progress = Math.min(1, elapsed / gatherDuration);
          const t = 1 - Math.pow(1 - progress, 3);

          grid.fill(0);
          opacities.fill(0);
          for (const p of gatheringParticles) {
            const px = p.startX + (p.targetX - p.startX) * t;
            const py = p.startY + (p.targetY - p.startY) * t;
            const col = Math.floor(px / cellSize);
            const row = Math.floor(py / cellSize);
            if (col >= 0 && col < columns && row >= 0 && row < rows) {
              const idx = row * columns + col;
              grid[idx] = 1;
              opacities[idx] = 1.0;
            }
          }
        } else {
          // Normal start: seed grid with current SVG blocks
          const targets = getSVGTargets();
          if (targets.length > 0 && columns > 0 && rows > 0) {
            grid.fill(0);
            opacities.fill(0);
            for (const target of targets) {
              const col = Math.floor(target.x / cellSize);
              const row = Math.floor(target.y / cellSize);
              if (col >= 0 && col < columns && row >= 0 && row < rows) {
                const idx = row * columns + col;
                grid[idx] = 1;
                opacities[idx] = 1.0;
              }
            }
          }
        }

        if (svg) svg.style.opacity = "0";
        canvas.style.opacity = "1";
        isVisible = true;
        startLoop();
      },
      stop: () => {
        if (stopTimeout) {
          clearTimeout(stopTimeout);
          stopTimeout = null;
        }

        // Prepare gathering particles
        const targets = getSVGTargets();
        const activeCells = [];
        let idx = 0;
        for (let r = 0; r < rows; r++) {
          for (let c = 0; c < columns; c++) {
            if (grid[idx] === 1 || opacities[idx] > 0.05) {
              activeCells.push({
                x: c * cellSize + drawSize / 2,
                y: r * cellSize + drawSize / 2,
              });
            }
            idx++;
          }
        }

        gatheringParticles = [];
        const assignedIndices = new Set();
        for (const target of targets) {
          let closestCell = null;
          let minDistance = Infinity;
          let closestIndex = -1;
          for (let i = 0; i < activeCells.length; i++) {
            if (assignedIndices.has(i)) continue;
            const cell = activeCells[i];
            const dist = Math.hypot(cell.x - target.x, cell.y - target.y);
            if (dist < minDistance) {
              minDistance = dist;
              closestCell = cell;
              closestIndex = i;
            }
          }
          if (closestCell) {
            assignedIndices.add(closestIndex);
            gatheringParticles.push({
              startX: closestCell.x,
              startY: closestCell.y,
              targetX: target.x,
              targetY: target.y,
            });
          } else {
            gatheringParticles.push({
              startX: target.x,
              startY: target.y,
              targetX: target.x,
              targetY: target.y,
            });
          }
        }

        // Clear grid active state so only the morphing cells show at their dynamic positions
        grid.fill(0);

        if (svg) svg.style.opacity = "0.6";
        canvas.style.opacity = "0";

        isGathering = true;
        gatherStartTime = performance.now();
        isVisible = true;
        startLoop();
      }
    };
  }

  function init() {
    updateTime();
    setInterval(updateTime, 1000);
    updateWeather();
    setInterval(updateWeather, 30 * 60 * 1000);

    const canvas = document.getElementById("footer-game-of-life-canvas") as HTMLCanvasElement | null;
    const footer = canvas?.closest("footer");
    if (canvas && footer) {
      const gol = initFooterGameOfLife(canvas);
      if (gol) {
        footer.addEventListener("mouseenter", () => gol.start());
        footer.addEventListener("mouseleave", () => gol.stop());
      }
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
