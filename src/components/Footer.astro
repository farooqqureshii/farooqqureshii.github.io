---
// Generate randomized dot positions and delay values for a 6x6 background pattern
const cols = 6;
const rows = 6;
const spacing = 5.333;
const radius = 1.667;

const bgDots = [];
for (let i = 0; i < cols; i++) {
  for (let j = 0; j < rows; j++) {
    const cx = 2.667 + i * spacing;
    const cy = 2.667 + j * spacing;
    const delay = Math.floor(Math.random() * 1000);
    const minOpacity = (Math.random() * 0.4 + 0.15).toFixed(2);
    bgDots.push({ cx, cy, delay, minOpacity });
  }
}
---

<footer class="relative select-none">
  <svg
    id="footer-svg-icon"
    class="text-zinc-500 dark:text-zinc-400"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <defs>
      <pattern id="dot-pattern" width="14" height="14" patternUnits="userSpaceOnUse" viewBox="0 0 105 105">
        <circle cx="12.5" cy="12.5" r="12.5" fill="currentColor" class="pulse-circle-icon" style="animation-delay: -0ms;"/>
        <circle cx="12.5" cy="52.5" r="12.5" fill="currentColor" fill-opacity=".5" class="pulse-circle-icon" style="animation-delay: -100ms;"/>
        <circle cx="52.5" cy="12.5" r="12.5" fill="currentColor" class="pulse-circle-icon" style="animation-delay: -300ms;"/>
        <circle cx="52.5" cy="52.5" r="12.5" fill="currentColor" class="pulse-circle-icon" style="animation-delay: -600ms;"/>
        <circle cx="92.5" cy="12.5" r="12.5" fill="currentColor" class="pulse-circle-icon" style="animation-delay: -800ms;"/>
        <circle cx="92.5" cy="52.5" r="12.5" fill="currentColor" class="pulse-circle-icon" style="animation-delay: -400ms;"/>
        <circle cx="12.5" cy="92.5" r="12.5" fill="currentColor" class="pulse-circle-icon" style="animation-delay: -700ms;"/>
        <circle cx="52.5" cy="92.5" r="12.5" fill="currentColor" class="pulse-circle-icon" style="animation-delay: -500ms;"/>
        <circle cx="92.5" cy="92.5" r="12.5" fill="currentColor" class="pulse-circle-icon" style="animation-delay: -200ms;"/>
      </pattern>
      <pattern id="random-dot-pattern" width="32" height="32" patternUnits="userSpaceOnUse" viewBox="0 0 32 32">
        {bgDots.map(dot => (
          <circle 
            cx={dot.cx} 
            cy={dot.cy} 
            r={radius} 
            fill="currentColor"
            class="pulse-circle"
            style={`animation-delay: -${dot.delay}ms; --pulse-opacity: ${dot.minOpacity};`}
          />
        ))}
      </pattern>
    </defs>
    <rect class="icon-rect" width="100%" height="100%" fill="url(#dot-pattern)" />
    <rect class="bg-rect" width="100%" height="100%" fill="url(#random-dot-pattern)" />
  </svg>

  <p class="footer-text text-sm text-zinc-500 dark:text-zinc-400 relative z-10 m-0 leading-relaxed">
    It's <span id="ottawa-time" class="inline-block tabular-nums" style="min-width:5.5ch;">--:--:--</span> and <span id="ottawa-weather">--°C</span> in Ottawa, Ontario.
    <span id="footer-icon-anchor" class="inline-block w-[14px] h-[14px] ml-1.5 align-middle"></span>
  </p>
</footer>

<style>
  footer {
    position: relative;
    display: flex;
    align-items: center;
    padding: 12px 0;
    margin-top: 12px;
    overflow: hidden;
    width: 100%;
  }

  #footer-svg-icon {
    position: absolute;
    pointer-events: none;
    z-index: 0;
    opacity: 0.6;
    transition:
      left 450ms cubic-bezier(0.23, 1, 0.32, 1),
      top 450ms cubic-bezier(0.23, 1, 0.32, 1),
      width 450ms cubic-bezier(0.23, 1, 0.32, 1),
      height 450ms cubic-bezier(0.23, 1, 0.32, 1),
      opacity 450ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  #footer-svg-icon .bg-rect {
    opacity: 0;
    transition: opacity 150ms ease-out; /* fast fade out on leave */
  }
  #footer-svg-icon .icon-rect {
    opacity: 1;
    transition: opacity 150ms ease-out; /* fast fade in on leave */
  }

  footer.is-hovered #footer-svg-icon {
    opacity: 0.22;
  }
  footer.is-hovered #footer-svg-icon .bg-rect {
    opacity: 1;
    transition: opacity 400ms cubic-bezier(0.23, 1, 0.32, 1); /* smooth fade in on enter */
  }
  footer.is-hovered #footer-svg-icon .icon-rect {
    opacity: 0;
    transition: opacity 400ms cubic-bezier(0.23, 1, 0.32, 1); /* smooth fade out on enter */
  }

  html.dark footer.is-hovered #footer-svg-icon {
    opacity: 0.15;
  }

  @keyframes pulse-icon {
    0%, 100% {
      fill-opacity: 1;
    }
    50% {
      fill-opacity: 0.2;
    }
  }
  .pulse-circle-icon {
    animation: pulse-icon 1s infinite linear;
  }

  @keyframes pulse-dot {
    0%, 100% {
      fill-opacity: 1;
    }
    50% {
      fill-opacity: var(--pulse-opacity, 0.2);
    }
  }
  .pulse-circle {
    animation: pulse-dot 1s infinite linear;
  }
</style>

<script>
  const OTTAWA = { lat: 45.4215, lon: -75.6972 };
  const WEATHER_URL = `https://api.open-meteo.com/v1/forecast?latitude=${OTTAWA.lat}&longitude=${OTTAWA.lon}&current=temperature_2m&timezone=America%2FToronto`;

  function updateTime() {
    const t = new Date().toLocaleTimeString("en-CA", {
      timeZone: "America/Toronto",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: false,
    });
    const el = document.getElementById("ottawa-time");
    if (el) el.textContent = t;
  }

  async function updateWeather() {
    const el = document.getElementById("ottawa-weather");
    if (!el) return;
    try {
      const res = await fetch(WEATHER_URL);
      if (!res.ok) throw new Error();
      const data = await res.json();
      const t = Math.round(data.current.temperature_2m);
      el.textContent = `${t}°C`;
    } catch {
      el.textContent = "—°C";
    }
  }

  function initFooterInteraction() {
    const footer = document.querySelector("footer");
    const anchor = document.getElementById("footer-icon-anchor");
    const svg = document.getElementById("footer-svg-icon");
    if (!footer || !anchor || !svg) return;

    let isHovered = false;

    const updateSvgPosition = () => {
      if (isHovered) return;
      const anchorRect = anchor.getBoundingClientRect();
      const footerRect = footer.getBoundingClientRect();

      svg.style.left = `${anchorRect.left - footerRect.left}px`;
      svg.style.top = `${anchorRect.top - footerRect.top}px`;
      svg.style.width = `${anchorRect.width}px`;
      svg.style.height = `${anchorRect.height}px`;
    };

    // Calculate initial coordinates once view settles
    setTimeout(updateSvgPosition, 250);

    const onMouseEnter = () => {
      isHovered = true;
      footer.classList.add("is-hovered");
      
      // Transition to full background container
      svg.style.left = "0px";
      svg.style.top = "0px";
      svg.style.width = "100%";
      svg.style.height = "100%";
    };

    const onMouseLeave = () => {
      isHovered = false;
      footer.classList.remove("is-hovered");
      updateSvgPosition();
    };

    footer.addEventListener("mouseenter", onMouseEnter);
    footer.addEventListener("mouseleave", onMouseLeave);

    // Refresh boundaries on resizing
    window.addEventListener("resize", updateSvgPosition);
  }

  function init() {
    updateTime();
    // Protect interval duplicates
    if (!(window as any).__footer_intervals_setup__) {
      (window as any).__footer_intervals_setup__ = true;
      setInterval(updateTime, 1000);
      updateWeather();
      setInterval(updateWeather, 30 * 60 * 1000);
    }
    initFooterInteraction();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }

  document.addEventListener("astro:after-swap", init);
</script>

