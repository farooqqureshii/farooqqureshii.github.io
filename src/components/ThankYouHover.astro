---
---

<div class="hover-text-wrapper">
  <div class="marquee-strip top" aria-hidden="true">
    <div class="marquee-track go-left" id="top-track"></div>
  </div>

  <span class="main-text">Thank you for stopping by.</span>

  <div class="marquee-strip bottom" aria-hidden="true">
    <div class="marquee-track go-right" id="bot-track"></div>
  </div>
</div>

<script>
  const smiley = `<svg class="smiley" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="7"/>
    <ellipse cx="35" cy="40" rx="6" ry="8" fill="currentColor"/>
    <ellipse cx="65" cy="40" rx="6" ry="8" fill="currentColor"/>
    <path d="M28 62 Q50 82 72 62" stroke="currentColor" stroke-width="7" stroke-linecap="round" fill="none"/>
  </svg>`;

  const item = `<span class="marquee-item">HAVE A GREAT DAY ${smiley}</span>`;
  const repeated = item.repeat(18);
  const topTrack = document.getElementById('top-track');
  const botTrack = document.getElementById('bot-track');

  if (topTrack && botTrack) {
    topTrack.innerHTML = repeated;
    botTrack.innerHTML = repeated;
  }
</script>

<style>
  .hover-text-wrapper {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.2rem;
    cursor: default;
    vertical-align: baseline;
    line-height: 1;
  }

  .main-text {
    display: block;
    font: inherit;
    font-size: 0.92em;
    line-height: 1.05;
    letter-spacing: -0.01em;
    user-select: none;
    white-space: nowrap;
  }

  .marquee-strip {
    overflow: hidden;
    width: 100%;
    height: 11px;
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .marquee-track {
    display: flex;
    width: max-content;
    white-space: nowrap;
    will-change: transform;
    height: 100%;
    align-items: center;
  }

  .hover-text-wrapper:hover .marquee-strip {
    opacity: 1;
  }

  .hover-text-wrapper:hover .go-left {
    animation: slide-left 14s linear infinite;
  }

  .hover-text-wrapper:hover .go-right {
    animation: slide-right 14s linear infinite;
  }

  .marquee-item {
    font: inherit;
    font-size: 0.36em;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0 0.4rem;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: inherit;
    opacity: 0.45;
  }

  .smiley {
    width: 0.45rem;
    height: 0.45rem;
    flex-shrink: 0;
    opacity: 0.55;
  }

  @keyframes slide-left {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @keyframes slide-right {
    from {
      transform: translateX(-50%);
    }
    to {
      transform: translateX(0);
    }
  }
</style>
