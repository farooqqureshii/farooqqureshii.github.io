---
import { EMAIL_UOTTAWA } from "../consts";
---

<div class="email-reveal flashlight-item mt-4">
  <span class="email-default">Email</span>
  <span class="email-hover">
    <a href={`mailto:${EMAIL_UOTTAWA}`} class="email-address">{EMAIL_UOTTAWA}</a>
    <button type="button" id="email-copy-btn" class="copy-btn" aria-label="Copy email">
      <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="9" y="9" width="13" height="13" rx="2"/>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
      </svg>
      <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M20 6L9 17l-5-5"/>
      </svg>
      <span class="copy-label">Copy</span>
    </button>
  </span>
</div>

<script is:inline define:vars={{ EMAIL_UOTTAWA }}>
  (function() {
    const copyBtn = document.getElementById("email-copy-btn");
    if (!copyBtn) return;

    copyBtn.addEventListener("click", async (e) => {
      e.stopPropagation();
      try {
        await navigator.clipboard.writeText(EMAIL_UOTTAWA);
        copyBtn.classList.add("copied");
        copyBtn.querySelector(".copy-label").textContent = "Copied!";
        setTimeout(() => {
          copyBtn.classList.remove("copied");
          copyBtn.querySelector(".copy-label").textContent = "Copy";
        }, 2000);
      } catch (_) {}
    });
  })();
</script>

<style>
  .email-reveal {
    display: inline-block;
    position: relative;
    opacity: 0;
    animation: emailRevealIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    animation-delay: 355ms;
  }

  @keyframes emailRevealIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .email-default,
  .email-hover {
    display: inline-block;
    transition: opacity 0.2s ease;
  }

  .email-default {
    position: relative;
  }

  .email-hover {
    position: absolute;
    left: 0;
    top: 0;
    opacity: 0;
    pointer-events: none;
    white-space: nowrap;
  }

  .email-reveal:hover .email-default {
    opacity: 0;
    pointer-events: none;
  }

  .email-reveal:hover .email-hover {
    opacity: 1;
    pointer-events: auto;
  }

  .email-reveal:hover {
    min-width: 220px;
  }

  .email-address {
    text-decoration: none;
    color: inherit;
    font-size: inherit;
  }

  .email-address::after {
    display: none;
  }

  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: 0.5rem;
    padding: 0.125rem 0.375rem;
    font-size: 0.75rem;
    border: none;
    border-radius: 0.25rem;
    cursor: pointer;
    background: rgb(228 228 231);
    color: rgb(82 82 91);
    transition: background 0.2s, color 0.2s, transform 0.2s;
    vertical-align: middle;
  }

  .copy-btn:hover {
    background: rgb(212 212 216);
    transform: scale(1.02);
  }

  html.dark .copy-btn {
    background: rgb(63 63 70);
    color: rgb(161 161 170);
  }

  html.dark .copy-btn:hover {
    background: rgb(82 82 91);
  }

  .copy-btn .copy-icon,
  .copy-btn .check-icon {
    width: 0.875rem;
    height: 0.875rem;
  }

  .copy-btn .check-icon {
    display: none;
  }

  .copy-btn.copied .copy-icon {
    display: none;
  }

  .copy-btn.copied .check-icon {
    display: block;
    animation: checkPop 0.3s ease-out;
  }

  @keyframes checkPop {
    0% { transform: scale(0.5); opacity: 0; }
    70% { transform: scale(1.1); }
    100% { transform: scale(1); opacity: 1; }
  }

  .copy-btn.copied {
    background: rgb(34 197 94 / 0.2);
    color: rgb(22 163 74);
  }

  html.dark .copy-btn.copied {
    background: rgb(34 197 94 / 0.25);
    color: rgb(74 222 128);
  }
</style>
