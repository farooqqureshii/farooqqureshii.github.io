---
// Floating Selection Highlight and Text Formatting Menu
---

<div id="text-format-popup" class="text-format-popup hidden" role="tooltip">
  <div class="tf-row">
    <!-- Format buttons -->
    <button type="button" class="tf-btn" id="tf-btn-bold" title="Bold">
      <span style="font-weight: 800;">B</span>
    </button>
    <button type="button" class="tf-btn" id="tf-btn-italic" title="Italic">
      <span style="font-style: italic; font-family: Georgia, serif;">I</span>
    </button>

    <div class="tf-divider"></div>

    <!-- Color Swatches -->
    <button
      type="button"
      class="tf-swatch tf-swatch-pink"
      id="tf-swatch-pink"
      title="Pink highlight"
      data-color="pink"></button>
    <button
      type="button"
      class="tf-swatch tf-swatch-yellow"
      id="tf-swatch-yellow"
      title="Yellow highlight"
      data-color="yellow"></button>
    <button
      type="button"
      class="tf-swatch tf-swatch-blue"
      id="tf-swatch-blue"
      title="Blue highlight"
      data-color="blue"></button>
    <button
      type="button"
      class="tf-swatch tf-swatch-green"
      id="tf-swatch-green"
      title="Green highlight"
      data-color="green"></button>

    <div class="tf-divider"></div>

    <!-- Sizing buttons -->
    <button
      type="button"
      class="tf-btn tf-size-btn"
      id="tf-btn-h1"
      title="Heading 1 size">H1</button
    >
    <button
      type="button"
      class="tf-btn tf-size-btn"
      id="tf-btn-h2"
      title="Heading 2 size">H2</button
    >
    <button
      type="button"
      class="tf-btn tf-size-btn"
      id="tf-btn-h3"
      title="Heading 3 size">H3</button
    >

    <div class="tf-divider"></div>

    <!-- Clear formatting button -->
    <button
      type="button"
      class="tf-btn tf-btn-clear"
      id="tf-btn-clear"
      title="Clear formatting"
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-4 w-4"
      >
        <path d="M20 20H7L3 16C2 15 2 13 3 12L13 2L22 11L20 13M17 17L20 20"
        ></path>
      </svg>
    </button>
  </div>
</div>

<style>
  .text-format-popup {
    position: absolute;
    z-index: 100000;
    background: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 12px;
    padding: 6px;
    box-shadow:
      0 12px 32px -4px rgba(0, 0, 0, 0.1),
      0 4px 12px -2px rgba(0, 0, 0, 0.05),
      0 0 0 1px rgba(0, 0, 0, 0.02);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition:
      opacity 0.15s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.15s cubic-bezier(0.16, 1, 0.3, 1);
    transform: scale(0.96) translateY(4px);
    pointer-events: none;
    opacity: 0;
    display: flex;
  }

  .text-format-popup.hidden {
    display: none !important;
  }

  @media (max-width: 768px) {
    .text-format-popup {
      display: none !important;
    }
  }

  :global(html.dark) .text-format-popup {
    background: rgba(24, 24, 27, 0.85);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow:
      0 12px 32px -4px rgba(0, 0, 0, 0.28),
      0 4px 12px -2px rgba(0, 0, 0, 0.16),
      0 0 0 1px rgba(255, 255, 255, 0.02);
  }

  .text-format-popup.visible {
    opacity: 1;
    transform: scale(1) translateY(0);
    pointer-events: auto;
  }

  .tf-row {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .tf-btn {
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    border-radius: 8px;
    color: rgb(82, 82, 91);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    user-select: none;
    transition:
      background-color 0.12s ease,
      color 0.12s ease,
      transform 0.08s ease;
  }

  :global(html.dark) .tf-btn {
    color: rgb(161, 161, 170);
  }

  .tf-btn:hover {
    background: rgba(0, 0, 0, 0.05);
    color: rgb(24, 24, 27);
  }

  :global(html.dark) .tf-btn:hover {
    background: rgba(255, 255, 255, 0.06);
    color: rgb(244, 244, 245);
  }

  .tf-btn:active {
    transform: scale(0.94);
  }

  .tf-size-btn {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .tf-divider {
    width: 1px;
    height: 16px;
    background: rgba(0, 0, 0, 0.08);
    margin: 0 2px;
  }

  :global(html.dark) .tf-divider {
    background: rgba(255, 255, 255, 0.08);
  }

  /* Color Swatches */
  .tf-swatch {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.08);
    cursor: pointer;
    margin: 0 3px;
    padding: 0;
    transition:
      transform 0.12s ease,
      box-shadow 0.12s ease;
    position: relative;
  }

  :global(html.dark) .tf-swatch {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .tf-swatch:hover {
    transform: scale(1.2);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
  }

  .tf-swatch:active {
    transform: scale(0.95);
  }

  .tf-swatch-pink {
    background: #ff6bab;
  }
  .tf-swatch-yellow {
    background: #ffcd4d;
  }
  .tf-swatch-blue {
    background: #5bbbff;
  }
  .tf-swatch-green {
    background: #91d65b;
  }

  .tf-btn-clear {
    color: rgb(239, 68, 68);
  }

  :global(html.dark) .tf-btn-clear {
    color: rgb(248, 113, 113);
  }

  .tf-btn-clear:hover {
    background: rgba(239, 68, 68, 0.08);
    color: rgb(220, 38, 38);
  }

  :global(html.dark) .tf-btn-clear:hover {
    background: rgba(248, 113, 113, 0.1);
    color: rgb(252, 165, 165);
  }

  /* Smooth transitions for all formatted spans */
  :global(.tf-span) {
    transition:
      font-weight 0.25s cubic-bezier(0.23, 1, 0.32, 1),
      font-size 0.25s cubic-bezier(0.23, 1, 0.32, 1),
      font-style 0.25s cubic-bezier(0.23, 1, 0.32, 1),
      line-height 0.25s cubic-bezier(0.23, 1, 0.32, 1),
      transform 0.25s cubic-bezier(0.23, 1, 0.32, 1),
      opacity 0.25s cubic-bezier(0.23, 1, 0.32, 1),
      background-color 0.25s cubic-bezier(0.23, 1, 0.32, 1);
  }

  :global(.format-resetting-active .tf-span) {
    font-weight: inherit !important;
    font-style: inherit !important;
    font-size: inherit !important;
    line-height: inherit !important;
    transform: none !important;
    opacity: 1 !important;
    background-color: transparent !important;
  }

  :global([data-highlighters-overlay]) {
    pointer-events: none !important;
  }
</style>

<script>
  import { highlight } from "@highlighters/core";

  // Core implementation of the highlighter popup menu
  let currentRange: Range | null = null;
  let activeHighlighters = new Map<Element, any>();
  let resizeObserver: ResizeObserver | null = null;

  // Restore edits immediately upon script evaluation/DOMContentLoaded
  function applySavedAnnotations() {
    const pathname = window.location.pathname;
    let annotations: Record<string, Record<string, string>> = {};
    try {
      annotations = JSON.parse(
        localStorage.getItem("text-annotations:v1") || "{}",
      );
    } catch (e) {
      return;
    }

    const pageAnnotations = annotations[pathname];
    if (!pageAnnotations) return;

    // Proactive Cache Sanitization: If saved HTML has pointer-events: none or GradientShimmer, discard and clear the cache
    let hasCorruptedCache = false;
    Object.values(pageAnnotations).forEach((html) => {
      if (
        html.includes("pointer-events: none") ||
        html.includes("GradientShimmer") ||
        html.includes("data-gradient-shimmer")
      ) {
        hasCorruptedCache = true;
      }
    });

    if (hasCorruptedCache) {
      delete annotations[pathname];
      try {
        localStorage.setItem(
          "text-annotations:v1",
          JSON.stringify(annotations),
        );
        let originals = JSON.parse(
          localStorage.getItem("text-annotations-originals:v1") || "{}",
        );
        delete originals[pathname];
        localStorage.setItem(
          "text-annotations-originals:v1",
          JSON.stringify(originals),
        );
      } catch (e) {}
      updateResetButtonVisibility();
      return;
    }

    Object.keys(pageAnnotations).forEach((selector) => {
      try {
        const el = document.querySelector(selector);
        if (el) {
          el.innerHTML = pageAnnotations[selector];
        }
      } catch (err) {
        console.error(`Failed to restore selector "${selector}":`, err);
      }
    });

    updateResetButtonVisibility();
  }

  function blendColors(activeClasses: string[], isDark: boolean): string {
    const colorsMap: Record<string, { r: number; g: number; b: number }> =
      isDark
        ? {
            "format-hl-pink": { r: 255, g: 142, b: 187 },
            "format-hl-yellow": { r: 255, g: 224, b: 102 },
            "format-hl-blue": { r: 124, g: 208, b: 255 },
            "format-hl-green": { r: 170, g: 226, b: 123 },
          }
        : {
            "format-hl-pink": { r: 255, g: 107, b: 171 },
            "format-hl-yellow": { r: 255, g: 205, b: 77 },
            "format-hl-blue": { r: 91, g: 187, b: 255 },
            "format-hl-green": { r: 145, g: 214, b: 91 },
          };

    const activeRGBs = activeClasses
      .map((cls) => colorsMap[cls])
      .filter(Boolean);

    if (activeRGBs.length === 0) return "#ffcd4d"; // fallback
    if (activeRGBs.length === 1) {
      const { r, g, b } = activeRGBs[0];
      return `rgb(${r}, ${g}, ${b})`;
    }

    let r = activeRGBs[0].r;
    let g = activeRGBs[0].g;
    let b = activeRGBs[0].b;

    for (let i = 1; i < activeRGBs.length; i++) {
      const next = activeRGBs[i];
      if (isDark) {
        r = Math.round(255 - ((255 - r) * (255 - next.r)) / 255);
        g = Math.round(255 - ((255 - g) * (255 - next.g)) / 255);
        b = Math.round(255 - ((255 - b) * (255 - next.b)) / 255);
      } else {
        r = Math.round((r * next.r) / 255);
        g = Math.round((g * next.g) / 255);
        b = Math.round((b * next.b) / 255);
      }
    }

    return `rgb(${r}, ${g}, ${b})`;
  }

  function applyHighlighters() {
    const isDark = document.documentElement.classList.contains("dark");
    const blendMode = isDark ? ("screen" as const) : ("multiply" as const);

    const highlightOptions = (colorValue: string) => {
      return {
        color: colorValue,
        opacity: isDark ? 0.92 : 0.74,
        blendMode: blendMode,
        glow: {
          enabled: true,
          intensity: isDark ? 0.85 : 0.55,
          spread: isDark ? 10 : 7,
        },
        tip: {
          type: "chisel" as const,
          angle: 13,
          overshoot: 6,
          overshootJitter: 3.2,
          angleJitter: 3.5,
        },
        ink: {
          flow: isDark ? 0.95 : 0.84,
          viscosity: 0.16,
          feathering: 0.58,
          streakiness: 0.3,
          dryout: 0.05,
          startEndBuildup: 0.88,
          flowFade: 0.12,
        },
        paper: { absorbency: 0.82 },
        edge: {
          waviness: 2.2,
          roughness: 0.58,
          frequency: 14,
          cap: "round" as const,
          radius: 13,
        },
        speed: {
          enabled: true,
          sensitivity: 0.92,
          minDeposit: 0.24,
          dryoutBoost: 0.9,
          streakBoost: 0.26,
          featherReduce: 0.78,
          poolBoost: 0.96,
        },
        animation: {
          draw: false,
        },
      };
    };

    const highlightClasses = [
      "format-hl-pink",
      "format-hl-yellow",
      "format-hl-blue",
      "format-hl-green",
    ];
    const spans = document.querySelectorAll(
      highlightClasses.map((cls) => `.${cls}`).join(","),
    );

    // Keep track of elements processed in this run
    const currentElements = new Set<Element>();

    spans.forEach((el) => {
      currentElements.add(el);
      const activeClasses = highlightClasses.filter((cls) =>
        el.classList.contains(cls),
      );
      const blendedColor = blendColors(activeClasses, isDark);

      const existingHandle = activeHighlighters.get(el);
      if (existingHandle) {
        existingHandle.update(highlightOptions(blendedColor));
      } else {
        const handle = highlight(
          el as HTMLElement,
          highlightOptions(blendedColor),
        );
        activeHighlighters.set(el, handle);
      }
    });

    // Clean up any handles whose elements are no longer in the DOM or no longer have highlight classes
    for (const [el, handle] of activeHighlighters.entries()) {
      if (!currentElements.has(el) || !document.body.contains(el)) {
        try {
          handle.remove();
        } catch (e) {}
        activeHighlighters.delete(el);
      }
    }
  }

  // Setup selector paths
  function getUniqueSelector(el: HTMLElement): string {
    if (el.id) {
      return `#${el.id}`;
    }
    const parts: string[] = [];
    let current: HTMLElement | null = el;
    while (current && current.nodeType === Node.ELEMENT_NODE) {
      if (current.tagName === "BODY") {
        parts.unshift("body");
        break;
      }
      if (current.id) {
        parts.unshift(`#${current.id}`);
        break;
      }
      let sibCount = 0;
      let sibIndex = 0;
      const parent = current.parentNode;
      if (parent) {
        for (let sib = parent.firstChild; sib; sib = sib.nextSibling) {
          if (
            sib.nodeType === Node.ELEMENT_NODE &&
            (sib as HTMLElement).tagName === current.tagName
          ) {
            if (sib === current) {
              sibIndex = sibCount;
            }
            sibCount++;
          }
        }
      }
      const tag = current.tagName.toLowerCase();
      if (sibCount > 1) {
        parts.unshift(`${tag}:nth-of-type(${sibIndex + 1})`);
      } else {
        parts.unshift(tag);
      }
      current = parent as HTMLElement | null;
    }
    return parts.join(" > ");
  }

  // Update visibility of the header reset button
  function updateResetButtonVisibility() {
    const btn = document.getElementById("reset-annotations-btn");
    if (!btn) return;

    let hasEdits = false;
    try {
      const annotations = JSON.parse(
        localStorage.getItem("text-annotations:v1") || "{}",
      );
      const pathname = window.location.pathname;
      hasEdits =
        annotations[pathname] && Object.keys(annotations[pathname]).length > 0;
    } catch (e) {
      // ignore
    }

    if (hasEdits) {
      btn.classList.remove("hidden");
      btn.classList.add("flex");
    } else {
      btn.classList.add("hidden");
      btn.classList.remove("flex");
    }
  }

  function captureOriginalsBeforeEdit(range: Range) {
    const textNodes = getTextNodesInRange(range);
    const blocks = new Set<HTMLElement>();

    textNodes.forEach((node) => {
      let parent = node.parentNode as HTMLElement | null;
      while (parent) {
        const tag = parent.tagName.toLowerCase();
        if (
          [
            "p",
            "li",
            "h1",
            "h2",
            "h3",
            "h4",
            "h5",
            "h6",
            "blockquote",
            "pre",
            "figcaption",
            "header",
            "div",
            "section",
          ].includes(tag)
        ) {
          blocks.add(parent);
          break;
        }
        parent = parent.parentNode as HTMLElement | null;
      }
    });

    if (blocks.size === 0) {
      let parent = range.commonAncestorContainer as HTMLElement;
      if (parent.nodeType !== Node.ELEMENT_NODE)
        parent = parent.parentNode as HTMLElement;
      blocks.add(parent);
    }

    const pathname = window.location.pathname;
    let originals: Record<string, Record<string, string>> = {};
    try {
      originals = JSON.parse(
        localStorage.getItem("text-annotations-originals:v1") || "{}",
      );
    } catch (e) {
      // ignore
    }

    if (!originals[pathname]) {
      originals[pathname] = {};
    }

    blocks.forEach((block) => {
      const selector = getUniqueSelector(block);
      if (selector) {
        // Save original HTML ONLY if it wasn't saved before
        if (!originals[pathname][selector]) {
          originals[pathname][selector] = block.innerHTML;
        }
      }
    });

    localStorage.setItem(
      "text-annotations-originals:v1",
      JSON.stringify(originals),
    );
  }

  // Save modified block elements in localStorage
  function saveModifiedBlocks(range: Range) {
    const textNodes = getTextNodesInRange(range);
    const blocks = new Set<HTMLElement>();

    textNodes.forEach((node) => {
      let parent = node.parentNode as HTMLElement | null;
      while (parent) {
        const tag = parent.tagName.toLowerCase();
        if (
          [
            "p",
            "li",
            "h1",
            "h2",
            "h3",
            "h4",
            "h5",
            "h6",
            "blockquote",
            "pre",
            "figcaption",
            "header",
            "div",
            "section",
          ].includes(tag)
        ) {
          blocks.add(parent);
          break;
        }
        parent = parent.parentNode as HTMLElement | null;
      }
    });

    if (blocks.size === 0) {
      let parent = range.commonAncestorContainer as HTMLElement;
      if (parent.nodeType !== Node.ELEMENT_NODE)
        parent = parent.parentNode as HTMLElement;
      blocks.add(parent);
    }

    const pathname = window.location.pathname;
    let annotations: Record<string, Record<string, string>> = {};
    try {
      annotations = JSON.parse(
        localStorage.getItem("text-annotations:v1") || "{}",
      );
    } catch (e) {
      // ignore
    }

    if (!annotations[pathname]) {
      annotations[pathname] = {};
    }

    blocks.forEach((block) => {
      const selector = getUniqueSelector(block);
      if (selector) {
        annotations[pathname][selector] = block.innerHTML;
      }
    });

    localStorage.setItem("text-annotations:v1", JSON.stringify(annotations));
    updateResetButtonVisibility();
  }

  // Fetch all text nodes in a range
  function getTextNodesInRange(range: Range): Text[] {
    const textNodes: Text[] = [];
    const container = range.commonAncestorContainer;
    const root =
      container.nodeType === Node.ELEMENT_NODE
        ? container
        : container.parentNode;
    if (!root) return [];

    const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, null);

    while (walker.nextNode()) {
      const node = walker.currentNode as Text;
      if (node.parentElement?.closest(".email-tooltip, .tooltip, script, style")) {
        continue;
      }
      if (range.intersectsNode(node)) {
        if (
          node.nodeValue &&
          (node.nodeValue.trim().length > 0 ||
            node === range.startContainer ||
            node === range.endContainer)
        ) {
          textNodes.push(node);
        }
      }
    }

    if (container.nodeType === Node.TEXT_NODE) {
      const parentEl = container.parentElement;
      if (!parentEl?.closest(".email-tooltip, .tooltip, script, style")) {
        textNodes.push(container as Text);
      }
    }

    return textNodes;
  }

  // Trigger a smooth loop to reflow highlighters during transitions
  function triggerSmoothHighlightReflow() {
    const startTime = performance.now();
    const duration = 400; // slightly longer than transition to ensure it settles

    function step() {
      for (const handle of activeHighlighters.values()) {
        try {
          handle.update({});
        } catch (e) {
          // ignore
        }
      }
      const elapsed = performance.now() - startTime;
      if (elapsed < duration) {
        requestAnimationFrame(step);
      }
    }
    requestAnimationFrame(step);
  }

  // Finalize formatting changes by saving and updating highlighters
  function finalizeFormatChanges(range: Range) {
    saveModifiedBlocks(range);
    applyHighlighters();
    clearActiveSelection();
    triggerSmoothHighlightReflow();
  }

  // Wrap selections
  function wrapRangeInSpan(range: Range, styleClass: string) {
    const textNodes = getTextNodesInRange(range);
    if (textNodes.length === 0) return;

    const startContainer = range.startContainer;
    const startOffset = range.startOffset;
    const endContainer = range.endContainer;
    const endOffset = range.endOffset;

    const spansToAnimate: HTMLSpanElement[] = [];

    textNodes.forEach((node) => {
      const val = node.nodeValue || "";
      let start = 0;
      let end = val.length;

      if (node === startContainer) {
        start = startOffset;
      }
      if (node === endContainer) {
        end = endOffset;
      }

      if (start === end) return;

      const selectedText = val.substring(start, end);
      const parent = node.parentNode;
      if (!parent) return;

      // Optimize: if parent is already a tf-span covering the selection, update it in-place
      if (
        (parent as HTMLElement).classList.contains("tf-span") &&
        start === 0 &&
        end === val.length &&
        parent.childNodes.length === 1
      ) {
        (parent as HTMLElement).classList.add(styleClass);
        return;
      }

      const span = document.createElement("span");
      span.className = `tf-span ${styleClass}`;
      span.textContent = selectedText;

      const beforeText = document.createTextNode(val.substring(0, start));
      const afterText = document.createTextNode(val.substring(end));

      parent.insertBefore(span, node);
      if (afterText.nodeValue && afterText.nodeValue.length > 0) {
        parent.insertBefore(afterText, node.nextSibling);
      }
      if (beforeText.nodeValue && beforeText.nodeValue.length > 0) {
        parent.insertBefore(beforeText, span);
      }

      parent.removeChild(node);
      spansToAnimate.push(span);
    });

    // Force layout reflow to trigger transition
    if (spansToAnimate.length > 0) {
      spansToAnimate[0].offsetHeight;
    }
  }

  // Remove styling class from range
  function removeFormatClassInRange(range: Range, className: string) {
    const container = range.commonAncestorContainer;
    const root =
      container.nodeType === Node.ELEMENT_NODE
        ? container
        : container.parentNode;
    if (!root) return;

    const spans = (root as HTMLElement).querySelectorAll(`span.${className}`);
    spans.forEach((span) => {
      if (range.intersectsNode(span)) {
        span.classList.remove(className);
        // If it has no styling class and no styling left, unwrap it after transition completes
        if (span.className === "tf-span" && !span.getAttribute("style")) {
          setTimeout(() => {
            if (
              span.className === "tf-span" &&
              !span.getAttribute("style") &&
              span.parentNode
            ) {
              const parent = span.parentNode;
              while (span.firstChild) {
                parent.insertBefore(span.firstChild, span);
              }
              parent.removeChild(span);
              parent.normalize();
            }
          }, 250);
        }
      }
    });
  }

  // Toggle bold/italic format
  function toggleFormatClass(className: string) {
    if (!currentRange) return;

    const textNodes = getTextNodesInRange(currentRange);
    if (textNodes.length === 0) return;

    captureOriginalsBeforeEdit(currentRange);

    const hasClassAll = textNodes.every((node) => {
      let parent = node.parentNode as HTMLElement | null;
      while (
        parent &&
        parent !== currentRange!.commonAncestorContainer.parentNode
      ) {
        if (parent.classList && parent.classList.contains(className)) {
          return true;
        }
        parent = parent.parentNode as HTMLElement | null;
      }
      return false;
    });

    const range = currentRange;
    if (hasClassAll) {
      removeFormatClassInRange(range, className);
    } else {
      wrapRangeInSpan(range, className);
    }

    finalizeFormatChanges(range);
  }

  // Toggle highlighter highlight color
  function toggleHighlightClass(className: string) {
    if (!currentRange) return;

    const textNodes = getTextNodesInRange(currentRange);
    if (textNodes.length === 0) return;

    captureOriginalsBeforeEdit(currentRange);

    const hasClassAll = textNodes.every((node) => {
      let parent = node.parentNode as HTMLElement | null;
      while (
        parent &&
        parent !== currentRange!.commonAncestorContainer.parentNode
      ) {
        if (parent.classList && parent.classList.contains(className)) {
          return true;
        }
        parent = parent.parentNode as HTMLElement | null;
      }
      return false;
    });

    const range = currentRange;
    // DO NOT strip other highlight classes to allow overlapping highlights/blend colors
    if (hasClassAll) {
      removeFormatClassInRange(range, className);
    } else {
      wrapRangeInSpan(range, className);
    }

    finalizeFormatChanges(range);
  }

  // Change font sizing class
  function setSizeClass(sizeClass: string | null) {
    if (!currentRange) return;

    captureOriginalsBeforeEdit(currentRange);

    const range = currentRange;
    // Strip existing sizes
    const sizeClasses = ["format-size-h1", "format-size-h2", "format-size-h3"];
    sizeClasses.forEach((cls) => removeFormatClassInRange(range, cls));

    if (sizeClass) {
      wrapRangeInSpan(range, sizeClass);
    }

    finalizeFormatChanges(range);
  }

  // Clear all formatting in range
  function clearAllFormatting() {
    if (!currentRange) return;

    captureOriginalsBeforeEdit(currentRange);

    const range = currentRange;
    const allFormatClasses = [
      "format-bold",
      "format-italic",
      "format-hl-pink",
      "format-hl-yellow",
      "format-hl-blue",
      "format-hl-green",
      "format-size-h1",
      "format-size-h2",
      "format-size-h3",
    ];

    allFormatClasses.forEach((cls) => removeFormatClassInRange(range, cls));
    finalizeFormatChanges(range);
  }

  function clearActiveSelection() {
    const selection = window.getSelection();
    if (selection) selection.removeAllRanges();
    hidePopup();
  }

  // Popup visibility helpers
  const popup = document.getElementById("text-format-popup");

  function showPopup(rect: DOMRect) {
    if (!popup) return;
    popup.classList.remove("hidden");

    // Force a reflow for transition animation
    popup.getBoundingClientRect();
    popup.classList.add("visible");

    const popupWidth = popup.offsetWidth;
    const popupHeight = popup.offsetHeight;

    const parentRect = popup.offsetParent
      ? popup.offsetParent.getBoundingClientRect()
      : { left: 0, top: 0, width: window.innerWidth };
    const left = rect.left - parentRect.left + rect.width / 2 - popupWidth / 2;
    const top = rect.top - parentRect.top - popupHeight - 12;

    // Boundary constraints relative to offsetParent
    const minLeft = 8;
    const maxLeft =
      (popup.offsetParent
        ? (popup.offsetParent as HTMLElement).offsetWidth
        : window.innerWidth) -
      popupWidth -
      8;

    // Flip to bottom if there's not enough room above the selection
    let finalTop = top;
    if (rect.top - parentRect.top < popupHeight + 16) {
      finalTop = rect.bottom - parentRect.top + 12;
    }

    popup.style.left = `${Math.max(minLeft, Math.min(maxLeft, left))}px`;
    popup.style.top = `${finalTop}px`;
  }

  function hidePopup() {
    if (!popup) return;
    popup.classList.remove("visible");
    // Hide completely after transition finish
    setTimeout(() => {
      if (!popup.classList.contains("visible")) {
        popup.classList.add("hidden");
      }
    }, 150);
    currentRange = null;
  }

  // Selection detection triggers
  function handleSelectionCheck() {
    // Disable on mobile/tablet screen sizes to avoid conflicting with native browser text selection popups
    if (window.matchMedia("(max-width: 768px)").matches) {
      hidePopup();
      return;
    }

    const selection = window.getSelection();
    if (!selection || selection.rangeCount === 0 || selection.isCollapsed) {
      hidePopup();
      return;
    }

    const range = selection.getRangeAt(0);
    const ancestor = range.commonAncestorContainer;
    const parent =
      ancestor.nodeType === Node.ELEMENT_NODE
        ? (ancestor as HTMLElement)
        : (ancestor.parentNode as HTMLElement);

    // Check scope boundaries
    if (!parent || !parent.closest("main, article, header")) {
      hidePopup();
      return;
    }

    // Exclude components/inputs
    if (
      parent.closest(
        'button, input, textarea, select, [role="button"], #menu-overlay, #text-format-popup, .hamburger-btn',
      )
    ) {
      hidePopup();
      return;
    }

    // Don't pop up for empty space selections
    if (selection.toString().trim().length === 0) {
      hidePopup();
      return;
    }

    currentRange = range.cloneRange();

    const rect = range.getBoundingClientRect();
    showPopup(rect);
  }

  // Initialize listeners
  function initTextSelector() {
    applySavedAnnotations();
    applyHighlighters();

    if (resizeObserver) {
      resizeObserver.disconnect();
    }

    resizeObserver = new ResizeObserver(() => {
      for (const handle of activeHighlighters.values()) {
        try {
          handle.update({});
        } catch (e) {
          // ignore
        }
      }
    });

    if (document.body) {
      resizeObserver.observe(document.body);
    }

    // Event listeners for selection detection
    document.addEventListener("mouseup", () => {
      // Delay slightly to allow selection to finalize
      setTimeout(handleSelectionCheck, 10);
    });

    document.addEventListener("touchend", () => {
      setTimeout(handleSelectionCheck, 50);
    });

    // Dismiss popup when clicking elsewhere
    document.addEventListener("mousedown", (e) => {
      if (popup && !popup.contains(e.target as Node)) {
        // Only hide if the user isn't clicking to start a new selection in text
        const target = e.target as HTMLElement;
        if (
          !target.closest("main, article") ||
          target.closest("button, #text-format-popup")
        ) {
          hidePopup();
        }
      }
    });

    // Setup action button click handlers
    document
      .getElementById("tf-btn-bold")
      ?.addEventListener("click", () => toggleFormatClass("format-bold"));
    document
      .getElementById("tf-btn-italic")
      ?.addEventListener("click", () => toggleFormatClass("format-italic"));

    document
      .getElementById("tf-swatch-pink")
      ?.addEventListener("click", () => toggleHighlightClass("format-hl-pink"));
    document
      .getElementById("tf-swatch-yellow")
      ?.addEventListener("click", () =>
        toggleHighlightClass("format-hl-yellow"),
      );
    document
      .getElementById("tf-swatch-blue")
      ?.addEventListener("click", () => toggleHighlightClass("format-hl-blue"));
    document
      .getElementById("tf-swatch-green")
      ?.addEventListener("click", () =>
        toggleHighlightClass("format-hl-green"),
      );

    document
      .getElementById("tf-btn-h1")
      ?.addEventListener("click", () => setSizeClass("format-size-h1"));
    document
      .getElementById("tf-btn-h2")
      ?.addEventListener("click", () => setSizeClass("format-size-h2"));
    document
      .getElementById("tf-btn-h3")
      ?.addEventListener("click", () => setSizeClass("format-size-h3"));

    document
      .getElementById("tf-btn-clear")
      ?.addEventListener("click", clearAllFormatting);

    // Header Reset Button logic
    const resetBtn = document.getElementById("reset-annotations-btn");
    if (resetBtn) {
      resetBtn.addEventListener("click", () => {
        const pathname = window.location.pathname;
        let originals: Record<string, Record<string, string>> = {};
        try {
          originals = JSON.parse(
            localStorage.getItem("text-annotations-originals:v1") || "{}",
          );
        } catch (e) {
          // ignore
        }

        const pageOriginals = originals[pathname];
        if (pageOriginals) {
          Object.keys(pageOriginals).forEach((selector) => {
            try {
              const el = document.querySelector(selector);
              if (el) {
                el.innerHTML = pageOriginals[selector];
              }
            } catch (err) {
              console.error(`Failed to restore selector "${selector}":`, err);
            }
          });
        }

        // Clear active highlighters
        for (const handle of activeHighlighters.values()) {
          try {
            handle.remove();
          } catch (e) {}
        }
        activeHighlighters.clear();

        // Remove page annotations from localStorage
        let annotations: Record<string, Record<string, string>> = {};
        try {
          annotations = JSON.parse(
            localStorage.getItem("text-annotations:v1") || "{}",
          );
        } catch (e) {
          // ignore
        }
        delete annotations[pathname];
        localStorage.setItem(
          "text-annotations:v1",
          JSON.stringify(annotations),
        );

        delete originals[pathname];
        localStorage.setItem(
          "text-annotations-originals:v1",
          JSON.stringify(originals),
        );

        // Wipe any highlighter overlays immediately
        const overlays = document.querySelectorAll(
          "[data-highlighters-overlay]",
        );
        overlays.forEach((el) => el.remove());

        updateResetButtonVisibility();
      });
      updateResetButtonVisibility();
    }

    // Event delegation to restore homepage click listeners broken by DOM edits
    const handleLookAroundDelegate = (e: Event) => {
      const target = e.target as HTMLElement | null;
      if (
        target &&
        (target.id === "look-around-btn" || target.closest("#look-around-btn"))
      ) {
        e.preventDefault();
        if (document.getElementById("menu-overlay")) {
          document.dispatchEvent(
            new CustomEvent("toggle-hamburger-menu", {
              detail: { action: "open" },
            }),
          );
        } else {
          document.getElementById("hamburger-btn")?.click();
        }
      }
    };
    document.addEventListener("click", handleLookAroundDelegate);
    document.addEventListener("touchstart", handleLookAroundDelegate, {
      passive: false,
    });

    // Watch for theme changes to automatically refresh highlighters
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.attributeName === "class") {
          applyHighlighters();
        }
      });
    });
    observer.observe(document.documentElement, { attributes: true });
  }

  // Run on page load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTextSelector);
  } else {
    initTextSelector();
  }
</script>
